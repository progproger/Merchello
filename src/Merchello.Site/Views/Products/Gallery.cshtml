@model MerchelloProductViewModel
@using Umbraco.Cms.Core.Models
@using Umbraco.Cms.Core.Strings
@inherits UmbracoViewPage<MerchelloProductViewModel>
@{
    Layout = null;

    // Element Type properties (if configured)
    var heroImage = Model.Content.Value<MediaWithCrops>("heroImage");
    var productGallery = Model.Content.Value<IEnumerable<MediaWithCrops>>("productGallery");
    var description = Model.Content.Value<IHtmlEncodedString>("productDescription");
    var showOnHomepage = Model.Content.Value<bool>("showOnHomepage");
    var averageRating = Model.Content.Value<decimal>("averageRating");

    // Combine gallery sources: Element Type gallery + Merchello images
    var allGalleryImages = new List<string>();
    if (productGallery?.Any() == true)
    {
        allGalleryImages.AddRange(productGallery.Select(m => m.GetCropUrl(width: 1200) ?? m.Url() ?? ""));
    }
    allGalleryImages.AddRange(Model.Images);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@Model.MetaTitle</title>
    @if (!string.IsNullOrEmpty(Model.MetaDescription))
    {
        <meta name="description" content="@Model.MetaDescription" />
    }
    @if (!string.IsNullOrEmpty(Model.CanonicalUrl))
    {
        <link rel="canonical" href="@Model.CanonicalUrl" />
    }
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; line-height: 1.6; color: #333; background: #f5f5f5; }

        /* Gallery Layout */
        .gallery-page { display: flex; min-height: 100vh; }

        /* Main Gallery (left side - 70%) */
        .main-gallery { flex: 0 0 70%; background: #fff; position: relative; }
        .main-image { width: 100%; height: 70vh; object-fit: contain; background: #fafafa; }
        .thumbnail-strip { display: flex; gap: 5px; padding: 10px; overflow-x: auto; background: #fff; border-top: 1px solid #eee; }
        .thumbnail { width: 80px; height: 80px; object-fit: cover; cursor: pointer; opacity: 0.6; transition: opacity 0.2s; border: 2px solid transparent; }
        .thumbnail:hover, .thumbnail.active { opacity: 1; border-color: #3182ce; }

        /* Product Details (right side - 30%) */
        .product-details { flex: 0 0 30%; padding: 40px 30px; overflow-y: auto; max-height: 100vh; }

        /* Badges */
        .badges { display: flex; gap: 8px; margin-bottom: 15px; }
        .badge { padding: 4px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; }
        .badge-featured { background: #ffd700; color: #333; }
        .badge-sale { background: #e53e3e; color: white; }
        .badge-rating { background: #38a169; color: white; }

        /* Product Info */
        h1 { font-size: 1.8rem; margin-bottom: 10px; line-height: 1.3; }

        /* Rating */
        .rating { display: flex; align-items: center; gap: 5px; margin-bottom: 15px; }
        .stars { color: #fbbf24; }
        .rating-value { color: #666; font-size: 0.9rem; }

        /* Pricing */
        .pricing { margin: 20px 0; padding: 15px 0; border-top: 1px solid #eee; border-bottom: 1px solid #eee; }
        .price { font-size: 2rem; font-weight: bold; color: #2d3748; }
        .was-price { text-decoration: line-through; color: #999; font-size: 1rem; display: block; margin-top: 5px; }

        /* SKU */
        .sku { color: #888; font-size: 0.85rem; margin-bottom: 15px; }

        /* Stock */
        .stock-status { padding: 8px 0; font-size: 0.9rem; }
        .in-stock { color: #38a169; }
        .out-of-stock { color: #e53e3e; }
        .low-stock { color: #dd6b20; }

        /* Variant Selector */
        .variant-selector { margin: 20px 0; }
        .variant-selector label { display: block; font-weight: 600; margin-bottom: 8px; font-size: 0.9rem; }
        .variant-options { display: flex; flex-wrap: wrap; gap: 8px; }
        .variant-option { padding: 10px 16px; border: 2px solid #ddd; border-radius: 4px; cursor: pointer; transition: all 0.2s; font-size: 0.9rem; }
        .variant-option:hover { border-color: #3182ce; }
        .variant-option.selected { border-color: #3182ce; background: #ebf8ff; }
        .variant-option.unavailable { opacity: 0.4; cursor: not-allowed; text-decoration: line-through; }

        /* Color swatches */
        .color-swatch { width: 32px; height: 32px; border-radius: 50%; border: 2px solid #ddd; cursor: pointer; transition: all 0.2s; }
        .color-swatch:hover, .color-swatch.selected { border-color: #3182ce; transform: scale(1.1); }

        /* Add to Cart */
        .quantity-selector { display: flex; align-items: center; gap: 10px; margin: 20px 0; }
        .quantity-selector input { width: 60px; padding: 10px; border: 1px solid #ddd; border-radius: 4px; text-align: center; font-size: 1rem; }
        .add-to-cart { background: #3182ce; color: white; padding: 15px 30px; border: none; border-radius: 4px; font-size: 1rem; cursor: pointer; width: 100%; font-weight: 600; transition: background 0.2s; }
        .add-to-cart:hover { background: #2c5282; }
        .add-to-cart:disabled { background: #cbd5e0; cursor: not-allowed; }

        /* Description */
        .description { margin-top: 30px; padding-top: 20px; border-top: 1px solid #eee; }
        .description h3 { font-size: 1rem; margin-bottom: 10px; }
        .description-content { font-size: 0.95rem; color: #555; }

        /* Videos */
        .videos { margin-top: 20px; }
        .videos h3 { font-size: 1rem; margin-bottom: 10px; }
        .video-list { display: flex; flex-direction: column; gap: 10px; }
        .video-item { display: block; padding: 10px; background: #f7fafc; border-radius: 4px; text-decoration: none; color: #3182ce; }

        @@media (max-width: 1024px) {
            .gallery-page { flex-direction: column; }
            .main-gallery { flex: none; }
            .product-details { flex: none; max-height: none; }
        }
    </style>
</head>
<body>
    <div class="gallery-page">
        <!-- Main Gallery -->
        <div class="main-gallery">
            @if (allGalleryImages.Any())
            {
                <img id="mainImage" class="main-image"
                     src="@allGalleryImages.First()"
                     alt="@Model.ProductRoot.RootName" />

                @if (allGalleryImages.Count > 1)
                {
                    <div class="thumbnail-strip">
                        @foreach (var (image, index) in allGalleryImages.Select((img, i) => (img, i)))
                        {
                            <img class="thumbnail @(index == 0 ? "active" : "")"
                                 src="@image"
                                 alt="@Model.ProductRoot.RootName - Image @(index + 1)"
                                 onclick="setMainImage(this, '@image')" />
                        }
                    </div>
                }
            }
            else if (heroImage != null)
            {
                <img class="main-image"
                     src="@heroImage.GetCropUrl(width: 1200)"
                     alt="@Model.ProductRoot.RootName" />
            }
            else
            {
                <div class="main-image" style="display: flex; align-items: center; justify-content: center; color: #999;">
                    No images available
                </div>
            }
        </div>

        <!-- Product Details -->
        <div class="product-details">
            <!-- Badges -->
            <div class="badges">
                @if (showOnHomepage)
                {
                    <span class="badge badge-featured">Featured</span>
                }
                @if (Model.OnSale)
                {
                    <span class="badge badge-sale">Sale</span>
                }
                @if (averageRating > 0)
                {
                    <span class="badge badge-rating">@averageRating.ToString("0.0")</span>
                }
            </div>

            <h1>@Model.ProductRoot.RootName</h1>

            <!-- Rating (if set via Element Type) -->
            @if (averageRating > 0)
            {
                <div class="rating">
                    <span class="stars">@(new string('★', (int)Math.Round(averageRating)))@(new string('☆', 5 - (int)Math.Round(averageRating)))</span>
                    <span class="rating-value">(@averageRating.ToString("0.0") / 5)</span>
                </div>
            }

            <!-- SKU -->
            @if (!string.IsNullOrEmpty(Model.SelectedVariant.Sku))
            {
                <p class="sku">SKU: @Model.SelectedVariant.Sku</p>
            }

            <!-- Pricing -->
            <div class="pricing">
                <span class="price">@Model.Price.ToString("C")</span>
                @if (Model.OnSale && Model.PreviousPrice.HasValue)
                {
                    <span class="was-price">Was @Model.PreviousPrice.Value.ToString("C")</span>
                }
            </div>

            <!-- Stock Status -->
            <div class="stock-status">
                @if (Model.AvailableForPurchase)
                {
                    @if (Model.TrackStock && Model.TotalStock <= 5)
                    {
                        <span class="low-stock">Only @Model.TotalStock left in stock!</span>
                    }
                    else if (Model.TrackStock)
                    {
                        <span class="in-stock">@Model.TotalStock in stock</span>
                    }
                    else
                    {
                        <span class="in-stock">In Stock</span>
                    }
                }
                else
                {
                    <span class="out-of-stock">Out of Stock</span>
                }
            </div>

            <!-- Variant Options -->
            @if (Model.VariantOptions.Any())
            {
                foreach (var option in Model.VariantOptions)
                {
                    <div class="variant-selector">
                        <label>@option.Name</label>
                        <div class="variant-options">
                            @foreach (var value in option.ProductOptionValues)
                            {
                                @if (!string.IsNullOrEmpty(value.HexValue))
                                {
                                    <div class="color-swatch"
                                         style="background-color: @value.HexValue;"
                                         title="@value.Name"></div>
                                }
                                else
                                {
                                    <div class="variant-option">@value.Name</div>
                                }
                            }
                        </div>
                    </div>
                }
            }

            <!-- Direct Variant Links (for URL-based navigation) -->
            @if (Model.AllVariants.Count > 1)
            {
                <div class="variant-selector">
                    <label>Select Variant</label>
                    <div class="variant-options">
                        @foreach (var variant in Model.AllVariants)
                        {
                            var isSelected = Model.IsVariantSelected(variant);
                            <a href="@Model.GetVariantUrl(variant)"
                               class="variant-option @(isSelected ? "selected" : "") @(!variant.AvailableForPurchase ? "unavailable" : "")"
                               style="text-decoration: none; color: inherit;">
                                @(variant.Name ?? "Default")
                            </a>
                        }
                    </div>
                </div>
            }

            <!-- Quantity & Add to Cart -->
            <div class="quantity-selector">
                <label>Qty:</label>
                <input type="number" id="quantity" value="1" min="1" max="@(Model.TrackStock ? Model.TotalStock : 99)" />
            </div>

            @if (Model.AvailableForPurchase)
            {
                <button class="add-to-cart"
                        data-product-id="@Model.SelectedVariant.Id"
                        data-variant-sku="@Model.SelectedVariant.Sku">
                    Add to Basket
                </button>
            }
            else
            {
                <button class="add-to-cart" disabled>
                    Out of Stock
                </button>
            }

            <!-- Description -->
            @if (description != null)
            {
                <div class="description">
                    <h3>Description</h3>
                    <div class="description-content">
                        @description
                    </div>
                </div>
            }

            <!-- Videos -->
            @if (Model.Videos.Any())
            {
                <div class="videos">
                    <h3>Videos</h3>
                    <div class="video-list">
                        @foreach (var video in Model.Videos)
                        {
                            <a href="@video" class="video-item" target="_blank">
                                Watch Video
                            </a>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

    <script>
        function setMainImage(thumb, src) {
            document.getElementById('mainImage').src = src;
            document.querySelectorAll('.thumbnail').forEach(t => t.classList.remove('active'));
            thumb.classList.add('active');
        }
    </script>
</body>
</html>
