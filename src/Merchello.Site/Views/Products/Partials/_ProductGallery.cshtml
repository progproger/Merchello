@model MerchelloProductViewModel

<div class="col-lg-6 mb-4">
    <template x-if="images.length > 0">
        <div>
            <div class="swiper product-gallery-main mb-3" x-ref="galleryMain">
                <div class="swiper-wrapper">
                    <template x-for="(image, index) in images" :key="index">
                        <div class="swiper-slide">
                            <img :src="image" alt="@Model.ProductRoot.RootName" class="img-fluid rounded" />
                        </div>
                    </template>
                </div>
                <div class="swiper-button-prev"></div>
                <div class="swiper-button-next"></div>
            </div>

            <template x-if="images.length > 1">
                <div class="swiper product-gallery-thumbs" x-ref="galleryThumbs">
                    <div class="swiper-wrapper">
                        <template x-for="(image, index) in images" :key="'thumb-' + index">
                            <div class="swiper-slide">
                                <img :src="image" alt="@Model.ProductRoot.RootName" class="img-fluid rounded" />
                            </div>
                        </template>
                    </div>
                </div>
            </template>
        </div>
    </template>

    <template x-if="images.length === 0">
        <div class="product-placeholder bg-light d-flex align-items-center justify-content-center rounded" style="aspect-ratio: 1;">
            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor" class="text-muted" viewBox="0 0 16 16">
                <path d="M6.002 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0"/>
                <path d="M2.002 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2zm12 1a1 1 0 0 1 1 1v6.5l-3.777-1.947a.5.5 0 0 0-.577.093l-3.71 3.71-2.66-1.772a.5.5 0 0 0-.63.062L1.002 12V3a1 1 0 0 1 1-1z"/>
            </svg>
        </div>
    </template>
</div>
