@using Merchello.Core.Email.Models
@using Merchello.Core.Notifications.CustomerNotifications
@using Merchello.Email.Extensions
@model EmailModel<CustomerPasswordResetRequestedNotification>
@*
    Password Reset Email Template

    This template is sent when a customer requests a password reset during checkout.
    The reset link expires after 1 hour for security.

    Model: EmailModel<CustomerPasswordResetRequestedNotification>
    - Model.Notification.Customer - The customer requesting the reset
    - Model.Notification.ResetUrl - Full URL to reset password page (includes token)
    - Model.Notification.ExpiresUtc - When the reset link expires
    - Model.Notification.CustomerEmail - Customer's email (convenience property)
    - Model.Notification.CustomerName - Customer's name (convenience property)
    - Model.Store - Store context (name, logo, contact info)
*@

@Html.Mjml().EmailStart(
    "Reset Your Password",
    "You requested a password reset for your account")

@Html.Mjml().Header(Model.Store)

<mj-section>
  <mj-column>
    @Html.Mjml().Heading("Reset Your Password")
    @{
        var greeting = !string.IsNullOrWhiteSpace(Model.Notification.CustomerName)
            ? $"Hi {Model.Notification.CustomerName},"
            : "Hi,";
    }
    @Html.Mjml().Text(greeting)
    <mj-text>
      We received a request to reset your password. Click the button below to create a new password.
    </mj-text>
    <mj-text color="#666666">
      <strong>This link will expire in 1 hour</strong> for security reasons.
    </mj-text>
  </mj-column>
</mj-section>

<mj-section>
  <mj-column>
    @Html.Mjml().Button("Reset Password", Model.Notification.ResetUrl)
  </mj-column>
</mj-section>

<mj-section>
  <mj-column>
    <mj-text font-size="12px" color="#666666">
      If you didn't request this password reset, you can safely ignore this email.
      Your password will remain unchanged.
    </mj-text>
  </mj-column>
</mj-section>

<mj-section>
  <mj-column>
    <mj-text font-size="11px" color="#999999">
      If the button above doesn't work, copy and paste this link into your browser:
    </mj-text>
    <mj-text font-size="11px" color="#666666" word-break="break-all">
      <a href="@Model.Notification.ResetUrl" style="color: #666666;">@Model.Notification.ResetUrl</a>
    </mj-text>
  </mj-column>
</mj-section>

@Html.Mjml().Footer(Model.Store)
@Html.Mjml().EmailEnd()
