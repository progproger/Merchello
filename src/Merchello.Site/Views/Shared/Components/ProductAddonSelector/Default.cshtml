@model Merchello.Site.Shared.Components.ProductAddonSelector.ProductAddonSelectorViewModel

@{
    var priceFormat = $"N{Model.DecimalPlaces}";
    var isMultiSelectJs = Model.IsMultiSelect ? "true" : "false";
}

<div class="addon-group mb-3">
    <label class="form-label fw-semibold">
        @Model.Name
        @if (Model.IsRequired)
        {
            <span class="text-danger">*</span>
        }
    </label>

    @if (Model.UiType == "checkbox")
    {
        @foreach (var value in Model.Values)
        {
            <div class="form-check addon-item">
                <input type="checkbox"
                       class="form-check-input"
                       id="addon-@value.Id"
                       :checked="isAddonSelected('@Model.OptionId', '@value.Id')"
                       @@change="toggleAddon('@Model.OptionId', '@value.Id', @value.PriceAdjustment, @value.DisplayPriceAdjustment, $event.target.checked, @Html.Raw(isMultiSelectJs))" />
                <label class="form-check-label" for="addon-@value.Id">
                    @value.Name
                    @if (value.DisplayPriceAdjustment != 0)
                    {
                        <span class="addon-price @(value.DisplayPriceAdjustment > 0 ? "text-success" : "text-danger")">
                            (@(value.DisplayPriceAdjustment > 0 ? "+" : "")@Model.CurrencySymbol@value.DisplayPriceAdjustment.ToString(priceFormat))
                        </span>
                    }
                </label>
            </div>
        }
    }
    else if (Model.UiType == "colour")
    {
        @if (Model.UseSwiper)
        {
            <div class="option-swiper swiper">
                <div class="swiper-wrapper">
                    @foreach (var value in Model.Values)
                    {
                        var priceLabel = value.GetPriceLabel(Model.CurrencySymbol, Model.DecimalPlaces);
                        <div class="swiper-slide" style="width: auto;">
                            <button type="button"
                                    class="color-swatch"
                                    :class="{ 'selected': isAddonSelected('@Model.OptionId', '@value.Id') }"
                                    style="background-color: @(value.HexValue ?? "#ccc");"
                                    title="@value.Name@priceLabel"
                                    @@click="toggleAddon('@Model.OptionId', '@value.Id', @value.PriceAdjustment, @value.DisplayPriceAdjustment, !isAddonSelected('@Model.OptionId', '@value.Id'), @Html.Raw(isMultiSelectJs))">
                            </button>
                        </div>
                    }
                </div>
                <div class="swiper-button-prev swiper-button-sm"></div>
                <div class="swiper-button-next swiper-button-sm"></div>
            </div>
        }
        else
        {
            <div class="color-swatch-grid">
                @foreach (var value in Model.Values)
                {
                    var priceLabel = value.GetPriceLabel(Model.CurrencySymbol, Model.DecimalPlaces);
                    <button type="button"
                            class="color-swatch"
                            :class="{ 'selected': isAddonSelected('@Model.OptionId', '@value.Id') }"
                            style="background-color: @(value.HexValue ?? "#ccc");"
                            title="@value.Name@priceLabel"
                            @@click="toggleAddon('@Model.OptionId', '@value.Id', @value.PriceAdjustment, @value.DisplayPriceAdjustment, !isAddonSelected('@Model.OptionId', '@value.Id'), @Html.Raw(isMultiSelectJs))">
                    </button>
                }
            </div>
        }
    }
    else if (Model.UiType == "image")
    {
        @if (Model.UseSwiper)
        {
            <div class="option-swiper swiper">
                <div class="swiper-wrapper">
                    @foreach (var value in Model.Values)
                    {
                        var priceLabel = value.GetPriceLabel(Model.CurrencySymbol, Model.DecimalPlaces);
                        <div class="swiper-slide" style="width: auto;">
                            <button type="button"
                                    class="image-swatch"
                                    :class="{ 'selected': isAddonSelected('@Model.OptionId', '@value.Id') }"
                                    title="@value.Name@priceLabel"
                                    @@click="toggleAddon('@Model.OptionId', '@value.Id', @value.PriceAdjustment, @value.DisplayPriceAdjustment, !isAddonSelected('@Model.OptionId', '@value.Id'), @Html.Raw(isMultiSelectJs))">
                                @if (!string.IsNullOrEmpty(value.MediaUrl))
                                {
                                    <img src="@value.MediaUrl" alt="@value.Name" />
                                }
                                else
                                {
                                    <span>@value.Name</span>
                                }
                            </button>
                        </div>
                    }
                </div>
                <div class="swiper-button-prev swiper-button-sm"></div>
                <div class="swiper-button-next swiper-button-sm"></div>
            </div>
        }
        else
        {
            <div class="image-swatch-grid">
                @foreach (var value in Model.Values)
                {
                    var priceLabel = value.GetPriceLabel(Model.CurrencySymbol, Model.DecimalPlaces);
                    <button type="button"
                            class="image-swatch"
                            :class="{ 'selected': isAddonSelected('@Model.OptionId', '@value.Id') }"
                            title="@value.Name@priceLabel"
                            @@click="toggleAddon('@Model.OptionId', '@value.Id', @value.PriceAdjustment, @value.DisplayPriceAdjustment, !isAddonSelected('@Model.OptionId', '@value.Id'), @Html.Raw(isMultiSelectJs))">
                        @if (!string.IsNullOrEmpty(value.MediaUrl))
                        {
                            <img src="@value.MediaUrl" alt="@value.Name" />
                        }
                        else
                        {
                            <span>@value.Name</span>
                        }
                    </button>
                }
            </div>
        }
    }
    else if (Model.UiType == "radiobutton")
    {
        <div class="btn-group flex-wrap" role="group">
            @foreach (var value in Model.Values)
            {
                <input type="radio"
                       class="btn-check"
                       name="addon-@Model.OptionId"
                       id="addon-@Model.OptionId-@value.Id"
                       value="@value.Id"
                       :checked="isAddonSelected('@Model.OptionId', '@value.Id')"
                       @@change="selectAddonRadio('@Model.OptionId', '@value.Id', @value.PriceAdjustment, @value.DisplayPriceAdjustment)" />
                <label class="btn btn-outline-secondary" for="addon-@Model.OptionId-@value.Id">
                    @value.Name
                    @if (value.DisplayPriceAdjustment != 0)
                    {
                        <span class="addon-price-inline @(value.DisplayPriceAdjustment > 0 ? "text-success" : "text-danger")">
                            (@(value.DisplayPriceAdjustment > 0 ? "+" : "")@Model.CurrencySymbol@value.DisplayPriceAdjustment.ToString(priceFormat))
                        </span>
                    }
                </label>
            }
        </div>
    }
    else
    {
        @* Default: dropdown *@
        <select class="form-select"
                @@change="selectAddonRadio('@Model.OptionId', $event.target.value, parseFloat($event.target.options[$event.target.selectedIndex].dataset.price || 0), parseFloat($event.target.options[$event.target.selectedIndex].dataset.displayPrice || 0))">
            <option value="" data-price="0" data-display-price="0">-- Select --</option>
            @foreach (var value in Model.Values)
            {
                <option value="@value.Id" data-price="@value.PriceAdjustment" data-display-price="@value.DisplayPriceAdjustment">
                    @value.Name
                    @if (value.DisplayPriceAdjustment != 0)
                    {
                        @:(@(value.DisplayPriceAdjustment > 0 ? "+" : "")@Model.CurrencySymbol@value.DisplayPriceAdjustment.ToString(priceFormat))
                    }
                </option>
            }
        </select>
    }

    <div class="text-danger small mt-2"
         x-show="getAddonValidationError('@Model.OptionId')"
         x-text="getAddonValidationError('@Model.OptionId')"
         role="alert">
    </div>
</div>
