@model Merchello.Site.Shared.Components.PriceRangeSlider.PriceRangeSliderViewModel

@{
    var min = Model.RangeMin;
    var max = Model.RangeMax;
    var selectedMin = Model.SelectedMin ?? min;
    var selectedMax = Model.SelectedMax ?? max;
    // Prevent division by zero - if range is 0, use 1 as step
    var range = max - min;
    var step = range > 0 ? Math.Max(1, Math.Floor(range / 100)) : 1;
    // For CSS calculation, prevent division by zero
    var rangeForCalc = range > 0 ? range : 1;
    // Price format for SSR fallback
    var priceFormat = $"N{Model.DecimalPlaces}";
}

@if (range > 0)
{
    <div class="price-range-slider mb-4">
        <h6 class="fw-bold mb-3">Price Range</h6>

        <div class="d-flex justify-content-between mb-2">
            <span class="price-label" x-text="formatPrice(priceMin)">@Model.CurrencySymbol@selectedMin.ToString(priceFormat)</span>
            <span class="price-label" x-text="formatPrice(priceMax)">@Model.CurrencySymbol@selectedMax.ToString(priceFormat)</span>
        </div>

        <div class="range-slider-container">
            <div class="range-track"></div>
            <div class="range-selected"
                 :style="`left: ${((priceMin - @min) / @rangeForCalc) * 100}%; right: ${100 - ((priceMax - @min) / @rangeForCalc) * 100}%`"></div>
            <input type="range"
                   class="range-input range-min"
                   min="@min"
                   max="@max"
                   step="@step"
                   x-model.number="priceMin"
                   @@input="onPriceChange()">
            <input type="range"
                   class="range-input range-max"
                   min="@min"
                   max="@max"
                   step="@step"
                   x-model.number="priceMax"
                   @@input="onPriceChange()">
        </div>
    </div>
}
