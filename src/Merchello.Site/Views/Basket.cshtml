@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage<Basket>
@using System.Text.Json
@using Merchello.Core.Storefront.Dtos
@{
    Layout = "Website.cshtml";
    var basketData = (StorefrontBasketDto)ViewBag.BasketData;
    var configJson = JsonSerializer.Serialize(basketData, new JsonSerializerOptions
    {
        PropertyNamingPolicy = JsonNamingPolicy.CamelCase
    });
}

<div x-data='basketPage(@Html.Raw(configJson))' class="basket-page">
    <!-- Empty Basket State - always rendered, visibility controlled by Alpine -->
    <div class="text-center py-5" x-show="isEmpty" x-cloak>
        <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="currentColor" class="bi bi-cart-x text-muted mb-4" viewBox="0 0 16 16">
            <path d="M7.354 5.646a.5.5 0 1 0-.708.708L7.793 7.5 6.646 8.646a.5.5 0 1 0 .708.708L8.5 8.207l1.146 1.147a.5.5 0 0 0 .708-.708L9.207 7.5l1.147-1.146a.5.5 0 0 0-.708-.708L8.5 6.793z"/>
            <path d="M.5 1a.5.5 0 0 0 0 1h1.11l.401 1.607 1.498 7.985A.5.5 0 0 0 4 12h1a2 2 0 1 0 0 4 2 2 0 0 0 0-4h7a2 2 0 1 0 0 4 2 2 0 0 0 0-4h1a.5.5 0 0 0 .491-.408l1.5-8A.5.5 0 0 0 14.5 3H2.89l-.405-1.621A.5.5 0 0 0 2 1zm3.915 10L3.102 4h10.796l-1.313 7zM6 14a1 1 0 1 1-2 0 1 1 0 0 1 2 0m7 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0"/>
        </svg>
        <h2 class="h4 mb-3">Your basket is empty</h2>
        <p class="text-muted mb-4">Looks like you haven't added any items to your basket yet.</p>
        <a href="/" class="btn btn-primary btn-lg">
            Continue Shopping
        </a>
    </div>

    <!-- Basket With Items - always rendered, visibility controlled by Alpine -->
    <div x-show="!isEmpty" x-cloak>
            <h1 class="h3 mb-4">Your Basket <span class="text-muted fs-6" x-text="'(' + itemCount + ' ' + (itemCount === 1 ? 'item' : 'items') + ')'"></span></h1>

            <!-- Shipping Destination -->
            <div class="card mb-4" x-show="$store.country.code" x-cloak>
                <div class="card-body py-2">
                    <div class="row align-items-center g-2">
                        <div class="col-auto">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="text-muted" viewBox="0 0 16 16">
                                <path d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8m7.5-6.923c-.67.204-1.335.82-1.887 1.855A8 8 0 0 0 5.145 4H7.5zM4.09 4a9.3 9.3 0 0 1 .64-1.539 7 7 0 0 1 .597-.933A7 7 0 0 0 2.255 4zm-.582 3.5c.03-.877.138-1.718.312-2.5H1.674a7 7 0 0 0-.656 2.5zM4.847 5a12.5 12.5 0 0 0-.338 2.5H7.5V5zM8.5 5v2.5h2.99a12.5 12.5 0 0 0-.337-2.5zM4.51 8.5a12.5 12.5 0 0 0 .337 2.5H7.5V8.5zm3.99 0V11h2.653c.187-.765.306-1.608.338-2.5zM5.145 12q.208.58.468 1.068c.552 1.035 1.218 1.65 1.887 1.855V12zm.182 2.472a7 7 0 0 1-.597-.933A9.3 9.3 0 0 1 4.09 12H2.255a7 7 0 0 0 3.072 2.472M3.82 11a13.7 13.7 0 0 1-.312-2.5h-2.49c.062.89.291 1.733.656 2.5zm6.853 3.472A7 7 0 0 0 13.745 12H11.91a9.3 9.3 0 0 1-.64 1.539 7 7 0 0 1-.597.933M8.5 12v2.923c.67-.204 1.335-.82 1.887-1.855q.26-.487.468-1.068zm3.68-1h2.146c.365-.767.594-1.61.656-2.5h-2.49a13.7 13.7 0 0 1-.312 2.5m2.802-3.5a7 7 0 0 0-.656-2.5H12.18c.174.782.282 1.623.312 2.5zM11.27 2.461c.247.464.462.98.64 1.539h1.835a7 7 0 0 0-3.072-2.472c.218.284.418.598.597.933M10.855 4a8 8 0 0 0-.468-1.068C9.835 1.897 9.17 1.282 8.5 1.077V4z"/>
                            </svg>
                        </div>
                        <div class="col-auto">
                            <strong>Shipping to:</strong>
                        </div>
                        <div class="col-auto">
                            <span x-text="$store.country.name"></span>
                        </div>
                        <div class="col-auto" x-show="regions.length > 0">
                            <select class="form-select form-select-sm"
                                    x-model="selectedRegion"
                                    @@change="checkBasketAvailability()"
                                    style="min-width: 180px;">
                                <option value="">Select region...</option>
                                <template x-for="region in regions" :key="region.regionCode">
                                    <option :value="region.regionCode" x-text="region.regionName"></option>
                                </template>
                            </select>
                        </div>
                        <div class="col-auto" x-show="isLoadingAvailability">
                            <span class="spinner-border spinner-border-sm text-primary"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Availability Warning Banner - using template+x-if to avoid Bootstrap d-flex !important conflict -->
            <template x-if="!allItemsAvailable">
                <div class="alert alert-warning d-flex align-items-center mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="flex-shrink-0 me-2" viewBox="0 0 16 16">
                        <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767z"/>
                        <path d="M8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/>
                    </svg>
                    <div>
                        <strong>Some items cannot be shipped to your location.</strong>
                        Remove unavailable items or change your shipping destination to proceed.
                    </div>
                </div>
            </template>

            <div class="row">
                <!-- Basket Items -->
                <div class="col-lg-8">
                    <div class="card mb-4">
                        <ul class="list-group list-group-flush">
                            <template x-for="item in productItems" :key="item.id">
                                <li class="list-group-item py-3">
                                    <div class="row align-items-center">
                                        <!-- Product Info -->
                                        <div class="col-12 col-md-6 mb-3 mb-md-0">
                                            <h5 class="mb-1" x-text="item.productRootName || item.name"></h5>
                                            <template x-if="item.selectedOptions && item.selectedOptions.length > 0">
                                                <div class="mb-1">
                                                    <template x-for="opt in item.selectedOptions" :key="opt.optionName">
                                                        <div class="text-muted small" x-text="opt.optionName + ': ' + opt.valueName"></div>
                                                    </template>
                                                </div>
                                            </template>

                                            <!-- Availability Warning -->
                                            <div class="text-danger mt-1" x-show="!isItemAvailable(item.id)" x-cloak>
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="me-1" viewBox="0 0 16 16">
                                                    <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767z"/>
                                                    <path d="M8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/>
                                                </svg>
                                                <small x-text="getItemMessage(item.id)"></small>
                                            </div>

                                            <!-- Add-ons for this product -->
                                            <template x-for="addon in getAddonsForProduct(item.id, item.sku)" :key="addon.id">
                                                <div class="text-muted small mt-1">
                                                    <span x-text="addon.name"></span>
                                                    <span class="ms-1" x-text="'(+' + (addon.formattedDisplayUnitPriceWithAddons || addon.formattedDisplayUnitPrice || addon.formattedUnitPrice || '') + ')'"></span>
                                                </div>
                                            </template>
                                        </div>

                                        <!-- Quantity Controls -->
                                        <div class="col-6 col-md-3">
                                            <div class="input-group input-group-sm quantity-selector">
                                                <button type="button"
                                                        class="btn btn-outline-secondary"
                                                        :disabled="updatingItemId === item.id"
                                                        @@click="decrementQuantity(item)">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                                        <path d="M4 8a.5.5 0 0 1 .5-.5h7a.5.5 0 0 1 0 1h-7A.5.5 0 0 1 4 8"/>
                                                    </svg>
                                                </button>
                                                <input type="number"
                                                       class="form-control text-center"
                                                       :value="item.quantity"
                                                       min="1"
                                                       :disabled="updatingItemId === item.id"
                                                       @@change="updateQuantity(item.id, parseInt($event.target.value) || 1)"
                                                       style="max-width: 60px;" />
                                                <button type="button"
                                                        class="btn btn-outline-secondary"
                                                        :disabled="updatingItemId === item.id"
                                                        @@click="incrementQuantity(item)">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                                        <path d="M8 4a.5.5 0 0 1 .5.5v3h3a.5.5 0 0 1 0 1h-3v3a.5.5 0 0 1-1 0v-3h-3a.5.5 0 0 1 0-1h3v-3A.5.5 0 0 1 8 4"/>
                                                    </svg>
                                                </button>
                                            </div>
                                            <!-- Loading indicator -->
                                            <div x-show="updatingItemId === item.id" class="text-center mt-1">
                                                <span class="spinner-border spinner-border-sm text-primary"></span>
                                            </div>
                                        </div>

                                        <!-- Price & Remove -->
                                        <div class="col-6 col-md-3 text-end">
                                            <div class="fw-bold" x-text="item.formattedDisplayLineTotalWithAddons || item.formattedDisplayLineTotal"></div>
                                            <small class="text-muted" x-show="item.quantity > 1" x-text="(item.formattedDisplayUnitPriceWithAddons || item.formattedDisplayUnitPrice) + ' each'"></small>
                                            <div class="mt-2">
                                                <button type="button"
                                                        class="btn btn-link btn-sm text-danger p-0"
                                                        :disabled="removingItemId === item.id"
                                                        @@click="removeItem(item.id)">
                                                    <span x-show="removingItemId !== item.id">Remove</span>
                                                    <span x-show="removingItemId === item.id" x-cloak class="spinner-border spinner-border-sm"></span>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </li>
                            </template>
                        </ul>
                    </div>

                    <!-- Upsell Suggestions -->
                    <template x-if="upsellSuggestions.length > 0">
                        <div class="mb-4">
                            <template x-for="suggestion in upsellSuggestions" :key="suggestion.upsellRuleId">
                                <div class="card mb-3">
                                    <div class="card-header bg-light">
                                        <h5 class="mb-0" x-text="suggestion.heading"></h5>
                                        <template x-if="suggestion.message">
                                            <small class="text-muted" x-text="suggestion.message"></small>
                                        </template>
                                    </div>
                                    <template x-if="suggestion.products.length > 0">
                                        <div class="card-body">
                                            <div class="row g-3">
                                                <template x-for="product in suggestion.products" :key="product.productId">
                                                    <div class="col-6 col-md-3">
                                                        <a :href="product.url || '#'"
                                                           class="text-decoration-none text-dark d-block text-center"
                                                           @@click="trackUpsellClick(suggestion.upsellRuleId, product.productId)">
                                                            <template x-if="product.imageUrl">
                                                                <img :src="product.imageUrl" :alt="product.name" class="img-fluid mb-2 rounded" style="max-height: 150px; object-fit: contain;">
                                                            </template>
                                                            <template x-if="!product.imageUrl">
                                                                <div class="bg-light d-flex align-items-center justify-content-center rounded mb-2" style="height: 150px;">
                                                                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" class="text-muted" viewBox="0 0 16 16">
                                                                        <path d="M6.002 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0"/>
                                                                        <path d="M2.002 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2zm12 1a1 1 0 0 1 1 1v6.5l-3.777-1.947a.5.5 0 0 0-.577.093l-3.71 3.71-2.66-1.772a.5.5 0 0 0-.63.062L1.002 12V3a1 1 0 0 1 1-1z"/>
                                                                    </svg>
                                                                </div>
                                                            </template>
                                                            <div class="fw-bold small" x-text="product.name"></div>
                                                            <div class="text-primary" x-text="product.formattedPrice"></div>
                                                            <template x-if="product.onSale && product.formattedPreviousPrice">
                                                                <div class="text-muted text-decoration-line-through small" x-text="product.formattedPreviousPrice"></div>
                                                            </template>
                                                        </a>
                                                    </div>
                                                </template>
                                            </div>
                                        </div>
                                    </template>
                                </div>
                            </template>
                        </div>
                    </template>

                    <!-- Continue Shopping Link -->
                    <a href="/" class="btn btn-outline-secondary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-left me-2" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8"/>
                        </svg>
                        Continue Shopping
                    </a>
                </div>

                <!-- Order Summary -->
                <div class="col-lg-4">
                    <div class="card">
                        <div class="card-header bg-dark text-white">
                            <h5 class="mb-0">Order Summary</h5>
                        </div>
                        <div class="card-body">
                            <!-- Subtotal: show tax-inclusive when enabled -->
                            <div class="d-flex justify-content-between mb-2">
                                <span>Subtotal</span>
                                <span x-text="displayPricesIncTax ? formattedTaxInclusiveDisplaySubTotal : formattedDisplaySubTotal"></span>
                            </div>
                            <template x-if="discount > 0">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-success">Discount</span>
                                    <span class="text-success" x-text="'-' + (displayPricesIncTax ? formattedTaxInclusiveDisplayDiscount : formattedDisplayDiscount)"></span>
                                </div>
                            </template>
                            <!-- Estimated Shipping -->
                            <div class="d-flex justify-content-between mb-2">
                                <span>
                                    Est. Shipping
                                    <template x-if="shippingGroupCount > 1">
                                        <small class="text-muted" x-text="'(' + shippingGroupCount + ' shipments)'"></small>
                                    </template>
                                    <template x-if="isLoadingShipping">
                                        <span class="spinner-border spinner-border-sm text-primary ms-1"></span>
                                    </template>
                                </span>
                                <template x-if="hasShippingEstimate && !isLoadingShipping && displayEstimatedShipping > 0">
                                    <span x-text="displayPricesIncTax ? formattedTaxInclusiveDisplayShipping : formattedDisplayEstimatedShipping"></span>
                                </template>
                                <template x-if="hasShippingEstimate && !isLoadingShipping && displayEstimatedShipping === 0">
                                    <span class="text-success fw-semibold">FREE</span>
                                </template>
                                <template x-if="!hasShippingEstimate && !isLoadingShipping">
                                    <small class="text-muted">Calculated at checkout</small>
                                </template>
                            </div>
                            <!-- Tax: hide when tax-inclusive (tax is already included in subtotal) -->
                            <template x-if="!displayPricesIncTax">
                                <div class="d-flex justify-content-between mb-2">
                                    <span>Tax</span>
                                    <span x-text="formattedDisplayTax"></span>
                                </div>
                            </template>
                            <hr>
                            <div class="d-flex justify-content-between mb-3">
                                <strong x-text="hasShippingEstimate ? 'Est. Total' : 'Total'"></strong>
                                <strong class="fs-5" x-text="formattedEstimatedTotal"></strong>
                            </div>
                            <!-- Tax included message (Shopify style) -->
                            <div class="text-muted small text-end mb-3"
                                 x-show="displayPricesIncTax && taxIncludedMessage"
                                 x-text="taxIncludedMessage">
                            </div>

                            <!-- Checkout Button -->
                            <a href="/checkout/information"
                               class="btn btn-primary btn-lg w-100"
                               :class="{ 'disabled': !allItemsAvailable }"
                               :aria-disabled="!allItemsAvailable"
                               @@click="!allItemsAvailable && $event.preventDefault()">
                                Proceed to Checkout
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
</div>
