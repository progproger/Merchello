{
  "$schema": "appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "Umbraco": {
    "CMS": {
      "Global": {
        "Id": "f3fbc7e5-41c3-47ae-87f1-db358e298151",
        "SanitizeTinyMce": true
      },
      "ModelsBuilder": {
        "ModelsMode": "SourceCodeManual"
      },
      "Content": {
        "AllowEditInvariantFromNonDefault": true,
        "ContentVersionCleanupPolicy": {
          "EnableCleanup": true
        }
      },
      "Unattended": {
        "UpgradeUnattended": true,
        "UnattendedUserName": "Administrator",
        "UnattendedUserEmail": "admin@example.com",
        "UnattendedUserPassword": "1234567890"
      },
      "Security": {
        "AllowConcurrentLogins": false
      }
    }
  },
  "Merchello": {
    "InstallSeedData": true,
    "InvoiceNumberPrefix": "INV-",
    "StoreName": "Acme Store",
    "StoreAddress": "123 Commerce Street\nNew York, NY 10001\nUnited States",
    "StoreCurrencyCode": "USD",
    "DefaultShippingCountry": "US",
    "DisplayPricesIncTax": true,
    "ShowStockLevels": true,
    "DefaultRounding": "AwayFromZero",
    "LowStockThreshold": 5,
    "OrderGroupingStrategy": null,
    "OptionTypeAliases": ["colour", "size", "material", "pattern"],
    "OptionUiAliases": ["dropdown", "colour", "image", "checkbox", "radiobutton"],
    "MaxProductOptions": 5,
    "MaxOptionValuesPerOption": 20,
    "ProductViewLocations": ["~/Views/Products/"],

    "DefaultMemberGroup": "MerchelloCustomer",
    "DefaultMemberTypeAlias": "Member",

    "ShippingAutoSelectStrategy": "cheapest",
    "ProductDescriptionDataTypeKey": null,
    "WebsiteUrl": "",
    "DownloadTokenSecret": "",
    "DefaultDownloadLinkExpiryDays": 30,
    "DefaultMaxDownloadsPerLink": 0,

    "Cache": {
      "DefaultTtlSeconds": 300
    },

    "ExchangeRates": {
      "CacheTtlMinutes": 60,
      "RefreshIntervalMinutes": 60
    },

    "Webhooks": {
      "Enabled": true,
      "MaxRetries": 5,
      "RetryDelaysSeconds": [60, 300, 900, 3600, 14400],
      "DeliveryIntervalSeconds": 10,
      "DefaultTimeoutSeconds": 30,
      "MaxPayloadSizeBytes": 1000000,
      "DeliveryLogRetentionDays": 30
    },

    "Email": {
      "Enabled": true,
      "TemplateViewLocations": ["/Views/Emails/{0}.cshtml"],
      "DefaultFromAddress": null,
      "DefaultFromName": null,
      "MaxRetries": 3,
      "RetryDelaysSeconds": [60, 300, 900],
      "DeliveryRetentionDays": 30,
      "MaxAttachmentSizeBytes": 10485760,
      "MaxTotalAttachmentSizeBytes": 26214400,
      "AttachmentStoragePath": "App_Data/Email_Attachments",
      "AttachmentRetentionHours": 72,
      "Store": {
        "Name": null,
        "Email": null,
        "LogoUrl": null,
        "WebsiteUrl": null,
        "SupportEmail": null,
        "Phone": null
      },
      "Theme": {
        "PrimaryColor": "#007bff",
        "TextColor": "#333333",
        "BackgroundColor": "#f4f4f4",
        "FontFamily": "'Helvetica Neue', Helvetica, Arial, sans-serif",
        "SecondaryTextColor": "#666666",
        "ContentBackgroundColor": "#ffffff"
      }
    },

    "Checkout": {
      "HeaderBackgroundImageUrl": null,
      "HeaderBackgroundColor": null,
      "LogoUrl": null,
      "LogoPosition": "Left",
      "LogoMaxWidth": 200,
      "PrimaryColor": "#000000",
      "AccentColor": "#0066FF",
      "BackgroundColor": "#FFFFFF",
      "TextColor": "#333333",
      "ErrorColor": "#DC2626",
      "HeadingFontFamily": "system-ui",
      "BodyFontFamily": "system-ui",
      "CompanyName": null,
      "SupportEmail": null,
      "SupportPhone": null,
      "ShowExpressCheckout": true,
      "RequirePhone": false,
      "ConfirmationRedirectUrl": null,
      "TermsUrl": null,
      "PrivacyUrl": null,
      "CustomScriptUrl": "/js/checkout-analytics.js",
      "SessionSlidingTimeoutMinutes": 30,
      "SessionAbsoluteTimeoutMinutes": 240,
      "LogSessionExpirations": true,
      "OrderTerms": {
        "ShowCheckbox": true,
        "CheckboxText": "I agree to the {terms:Terms & Conditions} and {privacy:Privacy Policy}",
        "CheckboxRequired": true
      }
    },

    "Protocols": {
      "Enabled": true,
      "WellKnownPath": "/.well-known",
      "ManifestCacheDurationMinutes": 60,
      "RequireHttps": true,
      "MinimumTlsVersion": "1.3",
      "Ucp": {
        "Enabled": true,
        "Version": "2026-01-11",
        "RequireAuthentication": false,
        "AllowedAgents": ["*"],
        "SigningKeyRotationDays": 90,
        "WebhookTimeoutSeconds": 30,
        "WebhookRetryCount": 3,
        "Capabilities": {
          "Checkout": true,
          "Order": true,
          "IdentityLinking": false
        },
        "Extensions": {
          "Discount": true,
          "Fulfillment": true,
          "BuyerConsent": false,
          "Ap2Mandates": false
        }
      }
    },

    "AbandonedCheckout": {
      "Enabled": true,
      "AbandonmentThresholdHours": 1.0,
      "RecoveryExpiryDays": 30,
      "CheckIntervalMinutes": 15,
      "RecoveryUrlBase": "/checkout/recover",
      "FirstEmailDelayHours": 1,
      "ReminderEmailDelayHours": 24,
      "FinalEmailDelayHours": 48,
      "MaxRecoveryEmails": 3
    },

    "Invoices": {
      "Reminders": {
        "Enabled": true,
        "ReminderDaysBeforeDue": 7,
        "OverdueReminderIntervalDays": 7,
        "MaxOverdueReminders": 3,
        "CheckIntervalHours": 24
      }
    },

    "Fulfilment": {
      "Enabled": true,
      "PollingIntervalMinutes": 15,
      "MaxRetryAttempts": 5,
      "RetryDelaysMinutes": [5, 15, 30, 60, 120],
      "InventorySyncIntervalMinutes": 60,
      "ProductSyncOnSave": false,
      "SyncLogRetentionDays": 30,
      "WebhookLogRetentionDays": 7
    },

    "Upsells": {
      "Enabled": true,
      "MaxSuggestionsPerLocation": 3,
      "CacheDurationSeconds": 300,
      "EventRetentionDays": 90,
      "EnablePostPurchase": true,
      "PostPurchaseTimeoutSeconds": 60,
      "PostPurchaseFulfillmentHoldMinutes": 5
    }
  }
}
