{
  "$schema": "appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "Umbraco": {
    "CMS": {
      "Global": {
        "Id": "f3fbc7e5-41c3-47ae-87f1-db358e298151",
        "SanitizeTinyMce": true
      },
      "ModelsBuilder": {
        "ModelsMode": "SourceCodeManual"
      },
      "Content": {
        "AllowEditInvariantFromNonDefault": true,
        "ContentVersionCleanupPolicy": {
          "EnableCleanup": true
        }
      },
      "Unattended": {
        "UpgradeUnattended": true,
        "UnattendedUserName": "Administrator",
        "UnattendedUserEmail": "admin@example.com",
        "UnattendedUserPassword": "1234567890"
      },
      "Security": {
        "AllowConcurrentLogins": false
      }
    }
  },
  "Merchello": {
    "InstallSeedData": true,
    "InvoiceNumberPrefix": "INV-",
    "StoreName": "Acme Store",
    "StoreAddress": "123 Commerce Street\nNew York, NY 10001\nUnited States",
    "StoreCurrencyCode": "USD",
    "DefaultShippingCountry": "US",
    "DisplayPricesIncTax": true,
    "ShowStockLevels": true,
    "DefaultRounding": "AwayFromZero",
    "LowStockThreshold": 5,
    "OrderGroupingStrategy": null,
    "OptionTypeAliases": ["colour", "size", "material", "pattern"],
    "OptionUiAliases": ["dropdown", "colour", "image", "checkbox", "radiobutton"],
    "MaxProductOptions": 5,
    "MaxOptionValuesPerOption": 20,
    "ProductViewLocations": ["~/Views/Products/"],
    "ProductElementTypeAlias": null,

    "DefaultMemberGroup": "MerchelloCustomer",
    "DefaultMemberTypeAlias": "Member",

    "Cache": {
      "DefaultTtlSeconds": 300
    },

    "ExchangeRates": {
      "CacheTtlMinutes": 60,
      "RefreshIntervalMinutes": 60
    },

    "Webhooks": {
      "Enabled": true,
      "MaxRetries": 5,
      "RetryDelaysSeconds": [60, 300, 900, 3600, 14400],
      "DeliveryIntervalSeconds": 10,
      "DefaultTimeoutSeconds": 30,
      "MaxPayloadSizeBytes": 1000000,
      "DeliveryLogRetentionDays": 30
    },

    "Email": {
      "Enabled": true,
      "TemplateViewLocations": ["/Views/Emails/{0}.cshtml"],
      "DefaultFromAddress": null,
      "DefaultFromName": null,
      "MaxRetries": 3,
      "RetryDelaysSeconds": [60, 300, 900],
      "DeliveryRetentionDays": 30,
      "Store": {
        "Name": null,
        "Email": null,
        "LogoUrl": null,
        "WebsiteUrl": null,
        "SupportEmail": null,
        "Phone": null
      }
    },

    "Checkout": {
      "HeaderBackgroundImageUrl": null,
      "HeaderBackgroundColor": null,
      "LogoUrl": null,
      "LogoPosition": "Left",
      "LogoMaxWidth": 200,
      "PrimaryColor": "#000000",
      "AccentColor": "#0066FF",
      "BackgroundColor": "#FFFFFF",
      "TextColor": "#333333",
      "ErrorColor": "#DC2626",
      "HeadingFontFamily": "system-ui",
      "BodyFontFamily": "system-ui",
      "CompanyName": null,
      "SupportEmail": null,
      "SupportPhone": null,
      "ShowExpressCheckout": true,
      "RequirePhone": false,
      "ConfirmationRedirectUrl": null,
      "TermsUrl": null,
      "PrivacyUrl": null,
      "CustomScriptUrl": "/js/checkout-analytics.js"
    }
  }
}
