@model CheckoutViewModel
@{
    Layout = "~/App_Plugins/Merchello/Views/Checkout/_Layout.cshtml";
    var confirmation = Model.Confirmation;

    // Get customer name for personalization
    var customerName = confirmation?.ShippingAddress?.Name ?? confirmation?.BillingAddress?.Name;
    var firstName = customerName?.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault();
}

@if (confirmation == null)
{
    <!-- Order Not Found -->
    <div class="max-w-2xl mx-auto text-center py-12">
        <div class="mb-6">
            <div class="inline-flex items-center justify-center w-20 h-20 bg-red-100 rounded-full">
                <svg class="w-10 h-10 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </div>
        </div>

        <h1 class="font-heading text-3xl font-semibold text-gray-900 mb-2">Order not found</h1>
        <p class="text-gray-600 mb-8">We couldn't find the order you're looking for. It may have expired or the link is invalid.</p>

        <a href="/"
           class="inline-block px-8 py-3 bg-primary text-white font-medium rounded-lg hover:opacity-90 focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-all">
            Continue Shopping
        </a>
    </div>
}
else
{
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-0">
        <!-- Left Column: Order Details -->
        <div class="pt-6 lg:pr-12 pb-8">
            <!-- Header: Confirmation Number & Title -->
            <div class="mb-6">
                <div class="flex items-center gap-2 mb-2">
                    @if (confirmation.IsCancelled)
                    {
                        <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    }
                    else if (confirmation.IsRefunded)
                    {
                        <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"></path>
                        </svg>
                    }
                    else
                    {
                        <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    }
                    <p class="text-sm text-gray-600">Order #@confirmation.InvoiceNumber</p>
                </div>
                @if (confirmation.IsCancelled)
                {
                    <h1 class="font-heading text-2xl lg:text-3xl font-semibold text-gray-900">
                        Order Cancelled
                    </h1>
                }
                else if (confirmation.IsRefunded)
                {
                    <h1 class="font-heading text-2xl lg:text-3xl font-semibold text-gray-900">
                        Order Refunded
                    </h1>
                }
                else
                {
                    <h1 class="font-heading text-2xl lg:text-3xl font-semibold text-gray-900">
                        Thank you@(string.IsNullOrEmpty(firstName) ? "" : $", {firstName}")!
                    </h1>
                }
            </div>

            <!-- Order Status Card -->
            @if (confirmation.IsCancelled)
            {
                <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
                    <div class="flex items-start gap-3">
                        <div class="flex-shrink-0">
                            <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center">
                                <svg class="w-5 h-5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                </svg>
                            </div>
                        </div>
                        <div>
                            <h2 class="font-medium text-gray-900">This order has been cancelled</h2>
                            @if (!string.IsNullOrEmpty(confirmation.CancellationReason))
                            {
                                <p class="text-sm text-gray-600 mt-1">Reason: @confirmation.CancellationReason</p>
                            }
                            else
                            {
                                <p class="text-sm text-gray-600 mt-1">If you have questions, please contact support</p>
                            }
                        </div>
                    </div>
                </div>
            }
            else if (confirmation.IsRefunded)
            {
                <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
                    <div class="flex items-start gap-3">
                        <div class="flex-shrink-0">
                            <div class="w-10 h-10 bg-amber-100 rounded-full flex items-center justify-center">
                                <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"></path>
                                </svg>
                            </div>
                        </div>
                        <div>
                            <h2 class="font-medium text-gray-900">This order has been refunded</h2>
                            <p class="text-sm text-gray-600 mt-1">Your refund should appear within 5-10 business days</p>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 mb-6">
                    <div class="flex items-start gap-3">
                        <div class="flex-shrink-0">
                            <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center">
                                <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                </svg>
                            </div>
                        </div>
                        <div>
                            <h2 class="font-medium text-gray-900">Your order is confirmed</h2>
                        </div>
                    </div>
                </div>
            }

            <!-- Order Details Section -->
            <div class="border border-gray-200 rounded-lg">
                <h3 class="text-lg font-medium text-gray-900 p-4 pb-0">Order details</h3>

                <div class="divide-y divide-gray-200">
                    <!-- Contact & Payment -->
                    <div class="p-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <h4 class="text-sm font-medium text-gray-500 mb-1">Contact information</h4>
                            <p class="text-sm text-gray-900">@confirmation.CustomerEmail</p>
                        </div>

                        @if (!string.IsNullOrEmpty(confirmation.PaymentMethod))
                        {
                            <div>
                                <h4 class="text-sm font-medium text-gray-500 mb-1">Payment method</h4>
                                <p class="text-sm text-gray-900">@confirmation.PaymentMethod</p>
                            </div>
                        }
                    </div>

                    <!-- Addresses -->
                    <div class="p-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <!-- Shipping Address -->
                        <div>
                            <h4 class="text-sm font-medium text-gray-500 mb-1">Shipping address</h4>
                            <address class="text-sm text-gray-900 not-italic leading-relaxed">
                                @if (!string.IsNullOrEmpty(confirmation.ShippingAddress.Name))
                                {
                                    @confirmation.ShippingAddress.Name<br />
                                }
                                @if (!string.IsNullOrEmpty(confirmation.ShippingAddress.Company))
                                {
                                    @confirmation.ShippingAddress.Company<br />
                                }
                                @if (!string.IsNullOrEmpty(confirmation.ShippingAddress.AddressOne))
                                {
                                    @confirmation.ShippingAddress.AddressOne<br />
                                }
                                @if (!string.IsNullOrEmpty(confirmation.ShippingAddress.AddressTwo))
                                {
                                    @confirmation.ShippingAddress.AddressTwo<br />
                                }
                                @{
                                    var shipCity = confirmation.ShippingAddress.TownCity;
                                    var shipState = confirmation.ShippingAddress.CountyState;
                                    var shipCityState = string.Join(", ", new[] { shipCity, shipState }.Where(s => !string.IsNullOrEmpty(s)));
                                }
                                @if (!string.IsNullOrEmpty(shipCityState))
                                {
                                    @shipCityState<br />
                                }
                                @if (!string.IsNullOrEmpty(confirmation.ShippingAddress.PostalCode))
                                {
                                    @confirmation.ShippingAddress.PostalCode<br />
                                }
                                @if (!string.IsNullOrEmpty(confirmation.ShippingAddress.Country))
                                {
                                    @confirmation.ShippingAddress.Country
                                }
                                @if (!string.IsNullOrEmpty(confirmation.ShippingAddress.Phone))
                                {
                                    <br />@confirmation.ShippingAddress.Phone
                                }
                            </address>
                        </div>

                        <!-- Billing Address -->
                        <div>
                            <h4 class="text-sm font-medium text-gray-500 mb-1">Billing address</h4>
                            <address class="text-sm text-gray-900 not-italic leading-relaxed">
                                @if (!string.IsNullOrEmpty(confirmation.BillingAddress.Name))
                                {
                                    @confirmation.BillingAddress.Name<br />
                                }
                                @if (!string.IsNullOrEmpty(confirmation.BillingAddress.Company))
                                {
                                    @confirmation.BillingAddress.Company<br />
                                }
                                @if (!string.IsNullOrEmpty(confirmation.BillingAddress.AddressOne))
                                {
                                    @confirmation.BillingAddress.AddressOne<br />
                                }
                                @if (!string.IsNullOrEmpty(confirmation.BillingAddress.AddressTwo))
                                {
                                    @confirmation.BillingAddress.AddressTwo<br />
                                }
                                @{
                                    var billCity = confirmation.BillingAddress.TownCity;
                                    var billState = confirmation.BillingAddress.CountyState;
                                    var billCityState = string.Join(", ", new[] { billCity, billState }.Where(s => !string.IsNullOrEmpty(s)));
                                }
                                @if (!string.IsNullOrEmpty(billCityState))
                                {
                                    @billCityState<br />
                                }
                                @if (!string.IsNullOrEmpty(confirmation.BillingAddress.PostalCode))
                                {
                                    @confirmation.BillingAddress.PostalCode<br />
                                }
                                @if (!string.IsNullOrEmpty(confirmation.BillingAddress.Country))
                                {
                                    @confirmation.BillingAddress.Country
                                }
                                @if (!string.IsNullOrEmpty(confirmation.BillingAddress.Phone))
                                {
                                    <br />@confirmation.BillingAddress.Phone
                                }
                            </address>
                        </div>
                    </div>

                    <!-- Shipping Method -->
                    <div class="p-4">
                        <h4 class="text-sm font-medium text-gray-500 mb-1">Shipping method</h4>
                        @if (confirmation.Shipments.Count > 0)
                        {
                            @foreach (var shipment in confirmation.Shipments)
                            {
                                <p class="text-sm text-gray-900">
                                    @shipment.ShippingMethodName
                                    @if (!string.IsNullOrEmpty(shipment.DeliveryEstimate))
                                    {
                                        <span class="text-gray-500">(@shipment.DeliveryEstimate)</span>
                                    }
                                </p>
                            }
                        }
                        else
                        {
                            <p class="text-sm text-gray-900">Standard Shipping</p>
                        }
                    </div>
                </div>
            </div>

            <!-- Need Help & Continue Shopping -->
            <div class="mt-6 flex flex-col sm:flex-row items-start sm:items-center gap-4">
                <a href="/"
                   class="px-6 py-3 bg-primary text-white font-medium rounded-lg hover:opacity-90 focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-all text-center">
                    Continue shopping
                </a>
                @if (!string.IsNullOrEmpty(Model.Store.Email))
                {
                    <span class="text-sm text-gray-600">
                        Need help? <a href="mailto:@Model.Store.Email" class="text-accent hover:underline">Contact us</a>
                    </span>
                }
            </div>
        </div>

        <!-- Right Column: Order Summary (Shared Partial) -->
        <div class="relative lg:border-l lg:border-gray-200">
            <div class="hidden lg:block absolute inset-y-0 left-0 w-[200vw] bg-[#fafafa] -z-10"></div>
            <div class="pt-6 lg:pl-8 lg:pt-6 lg:pr-8 lg:sticky lg:top-0">
                @await Html.PartialAsync("~/App_Plugins/Merchello/Views/Checkout/_OrderSummary.cshtml", Model, new ViewDataDictionary(ViewData) {
                    { "Mode", "readonly" },
                    { "Confirmation", confirmation }
                })
            </div>
        </div>
    </div>
}

@section Scripts {
    <!-- Confirmation page protection (back button, cleanup) -->
    <script src="~/App_Plugins/Merchello/js/checkout/confirmation.js"></script>

    @if (confirmation != null && !confirmation.IsCancelled && !confirmation.IsRefunded)
    {
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                if (window.MerchelloCheckout) {
                    // Prevent duplicate purchase events on page refresh
                    var purchaseKey = 'merchello_purchase_' + '@confirmation.InvoiceId';
                    if (localStorage.getItem(purchaseKey)) {
                        console.debug('Purchase event already fired for invoice ' + '@confirmation.InvoiceNumber');
                        return;
                    }

                    // Mark this purchase as tracked
                    localStorage.setItem(purchaseKey, Date.now().toString());

                    window.MerchelloCheckout.emit('checkout:purchase', {
                        transaction_id: '@confirmation.InvoiceNumber',
                        currency: '@confirmation.DisplayCurrencyCode',
                        currency_symbol: '@confirmation.CurrencySymbol',
                        value: @confirmation.Total,
                        subtotal: @confirmation.SubTotal,
                        tax: @confirmation.Tax,
                        shipping: @confirmation.Shipping,
                        discount: @confirmation.Discount,
                        items: @Html.Raw(Model.LineItemsJson ?? "[]")
                    });
                }
            });
        </script>
    }
}
