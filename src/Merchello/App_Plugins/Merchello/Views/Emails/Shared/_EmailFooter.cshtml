@using Merchello.Core.Settings.Services.Interfaces
@model EmailStoreContext
@inject IMerchelloStoreSettingsService StoreSettingsService
@{
    var theme = StoreSettingsService.GetRuntimeSettings().Email.Theme;
    var addressParts = new List<string>();
    if (Model.Address != null)
    {
        if (!string.IsNullOrEmpty(Model.Address.AddressOne)) addressParts.Add(Model.Address.AddressOne);
        if (!string.IsNullOrEmpty(Model.Address.TownCity)) addressParts.Add(Model.Address.TownCity);
        if (!string.IsNullOrEmpty(Model.Address.PostalCode)) addressParts.Add(Model.Address.PostalCode);
    }
}
<mj-section background-color="@theme.BackgroundColor" padding="20px">
  <mj-column>
    <mj-divider border-color="#dddddd" />

    <mj-text align="center" color="@theme.SecondaryTextColor" font-size="12px">
      @Model.Name
      @if (addressParts.Count > 0)
      {
        <br/>@string.Join(", ", addressParts)
      }
    </mj-text>

    @if (!string.IsNullOrEmpty(Model.SupportEmail) || !string.IsNullOrEmpty(Model.Phone))
    {
    <mj-text align="center" color="@theme.SecondaryTextColor" font-size="12px">
      @if (!string.IsNullOrEmpty(Model.SupportEmail))
      {
        <text>Email: </text><a href="mailto:@Model.SupportEmail" style="color: @theme.PrimaryColor;">@Model.SupportEmail</a>
      }
      @if (!string.IsNullOrEmpty(Model.SupportEmail) && !string.IsNullOrEmpty(Model.Phone))
      {
        <text> | </text>
      }
      @if (!string.IsNullOrEmpty(Model.Phone))
      {
        <text>Phone: @Model.Phone</text>
      }
    </mj-text>
    }
  </mj-column>
</mj-section>
