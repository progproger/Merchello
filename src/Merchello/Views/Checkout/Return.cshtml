@model CheckoutViewModel
@{
    Layout = "~/Views/Checkout/_Layout.cshtml";
}

<div class="max-w-lg mx-auto text-center py-12" x-data="paymentReturn()" x-init="checkPaymentStatus()">
    <!-- Loading State -->
    <div x-show="isChecking" class="space-y-4">
        <div class="mx-auto w-16 h-16 flex items-center justify-center">
            <svg class="animate-spin h-12 w-12 text-accent" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
        </div>
        <h1 class="font-heading text-2xl font-semibold text-gray-900">Processing Your Payment</h1>
        <p class="text-gray-600">Please wait while we confirm your payment...</p>
    </div>

    <!-- Success State -->
    <div x-show="status === 'success'" x-cloak class="space-y-4">
        <div class="mx-auto w-16 h-16 bg-green-100 rounded-full flex items-center justify-center">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
        </div>
        <h1 class="font-heading text-2xl font-semibold text-gray-900">Payment Successful!</h1>
        <p class="text-gray-600">Redirecting to your order confirmation...</p>
    </div>

    <!-- Pending State -->
    <div x-show="status === 'pending'" x-cloak class="space-y-4">
        <div class="mx-auto w-16 h-16 bg-yellow-100 rounded-full flex items-center justify-center">
            <svg class="w-8 h-8 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
        </div>
        <h1 class="font-heading text-2xl font-semibold text-gray-900">Payment Processing</h1>
        <p class="text-gray-600" x-text="message"></p>
        <p class="text-sm text-gray-500">This may take a few moments. Please don't close this page.</p>
        <div class="pt-4">
            <button type="button"
                    @@click="checkPaymentStatus()"
                    class="px-6 py-2 bg-accent text-white rounded-lg hover:opacity-90 transition-colors">
                Check Status
            </button>
        </div>
    </div>

    <!-- Error State -->
    <div x-show="status === 'error'" x-cloak class="space-y-4">
        <div class="mx-auto w-16 h-16 bg-red-100 rounded-full flex items-center justify-center">
            <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </div>
        <h1 class="font-heading text-2xl font-semibold text-gray-900">Payment Failed</h1>
        <p class="text-gray-600" x-text="message"></p>
        <div class="pt-4 space-x-4">
            <a href="/checkout/payment"
               class="inline-block px-6 py-2 bg-accent text-white rounded-lg hover:opacity-90 transition-colors">
                Try Again
            </a>
            <a href="/"
               class="inline-block px-6 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors">
                Return to Store
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function paymentReturn() {
            return {
                isChecking: true,
                status: null, // 'success', 'pending', 'error'
                message: '',
                invoiceId: null,
                retryCount: 0,
                maxRetries: 10,

                async checkPaymentStatus() {
                    this.isChecking = true;

                    try {
                        // Get query parameters from URL
                        const params = new URLSearchParams(window.location.search);

                        // Build the API URL with query parameters
                        const apiUrl = '/api/merchello/checkout/return?' + params.toString();

                        const response = await fetch(apiUrl);
                        const result = await response.json();

                        this.invoiceId = result.invoiceId;
                        this.message = result.message || '';

                        if (result.success && result.paymentId) {
                            // Payment confirmed
                            this.status = 'success';
                            // Redirect to confirmation page after a short delay
                            setTimeout(() => {
                                window.location.href = `/checkout/confirmation/${this.invoiceId}`;
                            }, 1500);
                        } else if (result.success) {
                            // Payment pending (waiting for webhook)
                            this.status = 'pending';
                            this.retryCount++;

                            // Auto-retry after a delay if we haven't exceeded max retries
                            if (this.retryCount < this.maxRetries) {
                                setTimeout(() => this.checkPaymentStatus(), 3000);
                            }
                        } else {
                            // Payment failed
                            this.status = 'error';
                        }
                    } catch (error) {
                        console.error('Error checking payment status:', error);
                        this.status = 'error';
                        this.message = 'An error occurred while checking your payment status.';
                    } finally {
                        this.isChecking = false;
                    }
                }
            }
        }
    </script>
}
