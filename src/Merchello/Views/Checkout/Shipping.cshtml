@model CheckoutViewModel
@using Merchello.Core.Checkout.Dtos
@using System.Text.Json
@{
    Layout = "~/Views/Checkout/_Layout.cshtml";
    var shippingAddress = Model.Basket?.ShippingAddress;
    var addressSummary = shippingAddress != null
        ? $"{shippingAddress.AddressOne}, {shippingAddress.TownCity}, {shippingAddress.PostalCode}"
        : "No address provided";

    // Serialize shipping groups for Alpine.js
    var groupsJson = JsonSerializer.Serialize(Model.ShippingGroups.Select(g => new {
        groupId = g.GroupId.ToString(),
        groupName = g.GroupName,
        lineItems = g.LineItems.Select(li => new { li.Name, li.Quantity, li.FormattedAmount }),
        shippingOptions = g.ShippingOptions.Select(o => new {
            id = o.Id.ToString(),
            name = o.Name,
            deliveryDescription = o.DeliveryDescription,
            formattedCost = o.FormattedCost,
            cost = o.Cost,
            isNextDay = o.IsNextDay
        }),
        selectedOptionId = g.SelectedShippingOptionId?.ToString()
    }));
}

<div class="grid grid-cols-1 lg:grid-cols-12 gap-8" x-data="checkoutShipping()">
    <!-- Left Column: Shipping Options -->
    <div class="lg:col-span-7">
        <h1 class="font-heading text-2xl font-semibold mb-6">Shipping Method</h1>

        <!-- Address Summary -->
        <div class="mb-6 p-4 bg-gray-50 rounded-lg border border-gray-200">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-500">Ship to</p>
                    <p class="text-sm font-medium text-gray-900">@addressSummary</p>
                </div>
                <a href="/checkout/information" class="text-sm text-accent hover:underline">Change</a>
            </div>
        </div>

        @if (Model.ShippingGroups.Count == 0)
        {
            <!-- No shipping groups available -->
            <div class="p-6 bg-yellow-50 border border-yellow-200 rounded-lg">
                <p class="text-yellow-800">Unable to determine shipping options. Please ensure your shipping address is complete.</p>
                <a href="/checkout/information" class="mt-2 inline-block text-accent hover:underline">Update address</a>
            </div>
        }
        else
        {
            <!-- Shipping Groups -->
            <div class="space-y-8">
                @foreach (var group in Model.ShippingGroups)
                {
                    <div class="border border-gray-200 rounded-lg overflow-hidden" x-data="{ expanded: true }">
                        <!-- Group Header -->
                        <div class="bg-gray-50 px-4 py-3 border-b border-gray-200">
                            <div class="flex items-center justify-between">
                                <h2 class="font-medium text-gray-900">@group.GroupName</h2>
                                <span class="text-sm text-gray-500">@group.LineItems.Count item(s)</span>
                            </div>
                        </div>

                        <!-- Group Items (collapsible) -->
                        <div x-show="expanded" x-collapse class="px-4 py-3 bg-white border-b border-gray-100">
                            <ul class="space-y-2">
                                @foreach (var item in group.LineItems)
                                {
                                    <li class="flex items-center justify-between text-sm">
                                        <span class="text-gray-700">@item.Name <span class="text-gray-400">x @item.Quantity</span></span>
                                        <span class="text-gray-600">@item.FormattedAmount</span>
                                    </li>
                                }
                            </ul>
                        </div>

                        <!-- Shipping Options -->
                        <div class="p-4 space-y-3">
                            <p class="text-sm text-gray-600 mb-3">Select shipping method:</p>

                            @if (group.ShippingOptions.Count == 0)
                            {
                                <div class="p-4 bg-red-50 border border-red-200 rounded-lg">
                                    <p class="text-sm text-red-700">No shipping options available for these items to your address.</p>
                                </div>
                            }
                            else
                            {
                                @foreach (var option in group.ShippingOptions)
                                {
                                    var optionId = option.Id.ToString();
                                    var groupId = group.GroupId.ToString();
                                    <label class="flex items-center gap-4 p-4 border border-gray-200 rounded-lg cursor-pointer hover:border-accent transition-colors"
                                           :class="{ 'border-accent bg-accent/5': selections['@groupId'] === '@optionId' }">
                                        <input type="radio"
                                               name="shipping-@groupId"
                                               value="@optionId"
                                               x-model="selections['@groupId']"
                                               class="w-5 h-5 text-accent focus:ring-accent" />
                                        <div class="flex-1">
                                            <p class="font-medium text-gray-900">
                                                @option.Name
                                                @if (option.IsNextDay)
                                                {
                                                    <span class="ml-2 px-2 py-0.5 text-xs bg-green-100 text-green-800 rounded-full">Next Day</span>
                                                }
                                            </p>
                                            <p class="text-sm text-gray-500">@option.DeliveryDescription</p>
                                        </div>
                                        <span class="font-medium text-gray-900">
                                            @if (option.Cost == 0)
                                            {
                                                <span class="text-green-600">FREE</span>
                                            }
                                            else
                                            {
                                                @option.FormattedCost
                                            }
                                        </span>
                                    </label>
                                }
                            }
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Error Message -->
        <div x-show="errorMessage" x-cloak class="mt-4 p-4 bg-red-50 border border-red-200 rounded-lg">
            <p class="text-sm text-red-700" x-text="errorMessage"></p>
        </div>

        <!-- Navigation Buttons -->
        <div class="mt-8 flex items-center justify-between">
            <a href="/checkout/information" class="text-accent hover:underline flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                </svg>
                Return to information
            </a>

            <button type="button"
                    @@click="continueToPayment"
                    :disabled="!allGroupsSelected || isSubmitting"
                    class="px-8 py-3 bg-primary text-white font-medium rounded-lg hover:opacity-90 focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-all disabled:opacity-50 disabled:cursor-not-allowed">
                <span x-show="!isSubmitting">Continue to Payment</span>
                <span x-show="isSubmitting" x-cloak class="flex items-center gap-2">
                    <svg class="animate-spin h-5 w-5" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    Processing...
                </span>
            </button>
        </div>
    </div>

    <!-- Right Column: Order Summary -->
    <div class="lg:col-span-5">
        <div class="sticky top-8">
            @await Html.PartialAsync("_OrderSummary")
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function checkoutShipping() {
            const groups = @Html.Raw(groupsJson);

            // Initialize selections from server-side data
            const initialSelections = {};
            groups.forEach(g => {
                if (g.selectedOptionId) {
                    initialSelections[g.groupId] = g.selectedOptionId;
                }
            });

            return {
                groups: groups,
                selections: initialSelections,
                isSubmitting: false,
                errorMessage: '',

                get allGroupsSelected() {
                    return this.groups.every(g =>
                        g.shippingOptions.length === 0 || this.selections[g.groupId]
                    );
                },

                get totalShippingCost() {
                    let total = 0;
                    this.groups.forEach(g => {
                        const selectedId = this.selections[g.groupId];
                        if (selectedId) {
                            const option = g.shippingOptions.find(o => o.id === selectedId);
                            if (option) total += option.cost;
                        }
                    });
                    return total;
                },

                async continueToPayment() {
                    if (!this.allGroupsSelected) {
                        this.errorMessage = 'Please select a shipping method for all items.';
                        return;
                    }

                    this.isSubmitting = true;
                    this.errorMessage = '';

                    try {
                        // Convert string keys back to proper format for API
                        const selectionsPayload = {};
                        for (const [groupId, optionId] of Object.entries(this.selections)) {
                            selectionsPayload[groupId] = optionId;
                        }

                        const response = await fetch('/api/merchello/checkout/shipping', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify({
                                selections: selectionsPayload
                            })
                        });

                        const result = await response.json();

                        if (result.success) {
                            window.location.href = '/checkout/payment';
                        } else {
                            this.errorMessage = result.message || 'Failed to save shipping selections.';
                            if (result.errors) {
                                const errorMessages = Object.values(result.errors).join(' ');
                                if (errorMessages) {
                                    this.errorMessage = errorMessages;
                                }
                            }
                        }
                    } catch (error) {
                        console.error('Failed to save shipping:', error);
                        this.errorMessage = 'An error occurred. Please try again.';
                    } finally {
                        this.isSubmitting = false;
                    }
                }
            }
        }
    </script>
}
