@model CheckoutViewModel
@using Merchello.Core.Checkout.Dtos
@using System.Text.Json
@using System.Text.Encodings.Web
@{
    Layout = "~/Views/Checkout/_Layout.cshtml";
    var shippingAddress = Model.Basket?.ShippingAddress;
    var addressSummary = shippingAddress != null
        ? $"{shippingAddress.AddressOne}, {shippingAddress.TownCity}, {shippingAddress.PostalCode}"
        : "No address provided";

    // Serialize shipping groups for Alpine.js
    // Using JavaScriptEncoder.Default for defense-in-depth XSS protection
    // This escapes <, >, &, ', " and other characters that could break out of script context
    var jsonOptions = new JsonSerializerOptions
    {
        Encoder = JavaScriptEncoder.Default
    };
    var groupsJson = JsonSerializer.Serialize(Model.ShippingGroups.Select(g => new {
        groupId = g.GroupId.ToString(),
        groupName = g.GroupName,
        lineItems = g.LineItems.Select(li => new { li.Name, li.Quantity, li.FormattedAmount }),
        shippingOptions = g.ShippingOptions.Select(o => new {
            id = o.Id.ToString(),
            name = o.Name,
            deliveryDescription = o.DeliveryDescription,
            formattedCost = o.FormattedCost,
            cost = o.Cost,
            isNextDay = o.IsNextDay
        }),
        selectedOptionId = g.SelectedShippingOptionId?.ToString()
    }), jsonOptions);
}

<div class="grid grid-cols-1 lg:grid-cols-2 gap-0" x-data="checkoutShipping()">
    <!-- Screen reader announcements -->
    <div aria-live="polite" aria-atomic="true" class="sr-only" x-text="announcement"></div>

    <!-- Left Column: Shipping Options -->
    <div class="pt-8 lg:pr-12 pb-24 lg:pb-8">
        <!-- Contact & Address Summary (Shopify style) -->
        <div class="mb-6 border border-gray-200 rounded-lg divide-y divide-gray-200">
            <div class="flex items-center justify-between p-4">
                <div class="flex items-start gap-4 flex-1">
                    <span class="text-sm text-gray-500 w-16 flex-shrink-0">Contact</span>
                    <p class="text-sm text-gray-900">@(Model.Basket?.BillingAddress?.Email ?? "Not provided")</p>
                </div>
                <a href="/checkout/information" class="text-sm text-accent hover:underline">Change</a>
            </div>
            <div class="flex items-center justify-between p-4">
                <div class="flex items-start gap-4 flex-1">
                    <span class="text-sm text-gray-500 w-16 flex-shrink-0">Ship to</span>
                    <p class="text-sm text-gray-900">@addressSummary</p>
                </div>
                <a href="/checkout/information" class="text-sm text-accent hover:underline">Change</a>
            </div>
        </div>

        <h2 class="font-heading text-xl font-normal mb-4">Shipping method</h2>

        @if (Model.ShippingGroups.Count == 0)
        {
            <!-- No shipping groups available -->
            <div class="p-6 bg-yellow-50 border border-yellow-200 rounded-lg">
                <p class="text-yellow-800">Unable to determine shipping options. Please ensure your shipping address is complete.</p>
                <a href="/checkout/information" class="mt-2 inline-block text-accent hover:underline">Update address</a>
            </div>
        }
        else
        {
            <!-- Shipping Groups -->
            <div class="space-y-8">
                @foreach (var group in Model.ShippingGroups)
                {
                    <div class="border border-gray-200 rounded-lg overflow-hidden" x-data="{ expanded: true }">
                        <!-- Group Header -->
                        <button type="button"
                                @@click="expanded = !expanded"
                                :aria-expanded="expanded"
                                aria-controls="group-items-@group.GroupId"
                                class="w-full bg-gray-50 px-4 py-3 border-b border-gray-200 checkout-touch-target">
                            <div class="flex items-center justify-between">
                                <h2 class="font-medium text-gray-900">@group.GroupName</h2>
                                <div class="flex items-center gap-2">
                                    <span class="text-sm text-gray-500">@group.LineItems.Count item(s)</span>
                                    <svg class="w-5 h-5 text-gray-400 transition-transform"
                                         :class="{ 'rotate-180': expanded }"
                                         aria-hidden="true"
                                         fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                                    </svg>
                                </div>
                            </div>
                        </button>

                        <!-- Group Items (collapsible) -->
                        <div x-show="expanded" x-collapse id="group-items-@group.GroupId" class="px-4 py-3 bg-white border-b border-gray-100">
                            <ul class="space-y-2">
                                @foreach (var item in group.LineItems)
                                {
                                    <li class="flex items-center justify-between text-sm">
                                        <span class="text-gray-700">@item.Name <span class="text-gray-400">x @item.Quantity</span></span>
                                        <span class="text-gray-600">@item.FormattedAmount</span>
                                    </li>
                                }
                            </ul>
                        </div>

                        <!-- Shipping Options -->
                        <div class="p-4 space-y-3">
                            <p class="text-sm text-gray-600 mb-3">Select shipping method:</p>

                            @if (group.ShippingOptions.Count == 0)
                            {
                                <div class="p-4 bg-red-50 border border-red-200 rounded-lg">
                                    <p class="text-sm text-red-700">No shipping options available for these items to your address.</p>
                                </div>
                            }
                            else
                            {
                                @foreach (var option in group.ShippingOptions)
                                {
                                    var optionId = option.Id.ToString();
                                    var groupId = group.GroupId.ToString();
                                    var radioId = $"shipping-{groupId}-{optionId}";
                                    <label for="@radioId"
                                           class="flex items-center gap-4 p-4 border border-gray-200 rounded-lg cursor-pointer hover:border-accent transition-colors checkout-touch-target"
                                           :class="{ 'border-accent bg-accent/5': selections['@groupId'] === '@optionId' }">
                                        <span class="checkout-checkbox-wrapper">
                                            <input type="radio"
                                                   id="@radioId"
                                                   name="shipping-@groupId"
                                                   value="@optionId"
                                                   x-model="selections['@groupId']"
                                                   @@change="onShippingChange('@groupId', '@optionId', '@option.Name')"
                                                   class="w-5 h-5 text-accent focus:ring-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2" />
                                        </span>
                                        <div class="flex-1">
                                            <p class="font-medium text-gray-900">
                                                @option.Name
                                                @if (option.IsNextDay)
                                                {
                                                    <span class="ml-2 px-2 py-0.5 text-xs bg-green-100 text-green-800 rounded-full">Next Day</span>
                                                }
                                            </p>
                                            <p class="text-sm text-gray-500">@option.DeliveryDescription</p>
                                        </div>
                                        <span class="font-medium text-gray-900">
                                            @if (option.Cost == 0)
                                            {
                                                <span class="text-green-600">FREE</span>
                                            }
                                            else
                                            {
                                                @option.FormattedCost
                                            }
                                        </span>
                                    </label>
                                }
                            }
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Error Message -->
        <div x-show="errorMessage" x-cloak role="alert" class="mt-4 p-4 bg-red-50 border border-red-200 rounded-lg">
            <p class="text-sm text-red-700" x-text="errorMessage"></p>
        </div>

        <!-- Navigation Buttons (Desktop) -->
        <div class="mt-8 hidden lg:flex items-center justify-between">
            <a href="/checkout/information" class="checkout-link flex items-center gap-2">
                <svg class="w-4 h-4" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                </svg>
                Return to information
            </a>

            <button type="button"
                    @@click="continueToPayment"
                    :disabled="!allGroupsSelected || isSubmitting"
                    :aria-busy="isSubmitting"
                    class="checkout-button-primary">
                <span x-show="!isSubmitting">Continue to Payment</span>
                <span x-show="isSubmitting" x-cloak class="flex items-center gap-2">
                    <svg class="animate-spin h-5 w-5" aria-hidden="true" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    <span>Processing...</span>
                </span>
            </button>
        </div>
    </div>

    <!-- Right Column: Order Summary -->
    <div class="relative lg:border-l lg:border-gray-200">
        <!-- Background extending to viewport edge -->
        <div class="hidden lg:block absolute inset-y-0 left-0 w-[200vw] bg-[#fafafa] -z-10"></div>
        <div class="lg:pl-8 lg:pt-8 lg:pr-8">
            @await Html.PartialAsync("~/Views/Checkout/_OrderSummary.cshtml")
        </div>
    </div>

    <!-- Mobile Sticky Action Bar -->
    <div class="checkout-sticky-actions lg:hidden">
        <div class="flex flex-col gap-3">
            <button type="button"
                    @@click="continueToPayment"
                    :disabled="!allGroupsSelected || isSubmitting"
                    :aria-busy="isSubmitting"
                    class="w-full checkout-button-primary">
                <span x-show="!isSubmitting">Continue to Payment</span>
                <span x-show="isSubmitting" x-cloak class="flex items-center justify-center gap-2">
                    <svg class="animate-spin h-5 w-5" aria-hidden="true" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    <span>Processing...</span>
                </span>
            </button>
            <a href="/checkout/information" class="text-center checkout-link text-sm">
                Return to information
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function checkoutShipping() {
            const groups = @Html.Raw(groupsJson);

            // Initialize selections from server-side data
            const initialSelections = {};
            groups.forEach(g => {
                if (g.selectedOptionId) {
                    initialSelections[g.groupId] = g.selectedOptionId;
                }
            });

            return {
                groups: groups,
                selections: initialSelections,
                isSubmitting: false,
                errorMessage: '',
                announcement: '',

                get allGroupsSelected() {
                    return this.groups.every(g =>
                        g.shippingOptions.length === 0 || this.selections[g.groupId]
                    );
                },

                get totalShippingCost() {
                    let total = 0;
                    this.groups.forEach(g => {
                        const selectedId = this.selections[g.groupId];
                        if (selectedId) {
                            const option = g.shippingOptions.find(o => o.id === selectedId);
                            if (option) total += option.cost;
                        }
                    });
                    return total;
                },

                // Announce message to screen readers
                announce(message) {
                    this.announcement = '';
                    setTimeout(() => {
                        this.announcement = message;
                    }, 100);
                },

                // Handle shipping option change for analytics/accessibility
                onShippingChange(groupId, optionId, optionName) {
                    this.announce(`Selected ${optionName} shipping`);
                    // Emit analytics event
                    if (window.MerchelloCheckout) {
                        window.MerchelloCheckout.emit('checkout:shipping_selected', {
                            groupId: groupId,
                            optionId: optionId,
                            optionName: optionName
                        });
                    }
                },

                async continueToPayment() {
                    if (!this.allGroupsSelected) {
                        this.errorMessage = 'Please select a shipping method for all items.';
                        this.announce(this.errorMessage);
                        return;
                    }

                    this.isSubmitting = true;
                    this.errorMessage = '';
                    this.announce('Saving shipping selections...');

                    try {
                        // Convert string keys back to proper format for API
                        const selectionsPayload = {};
                        for (const [groupId, optionId] of Object.entries(this.selections)) {
                            selectionsPayload[groupId] = optionId;
                        }

                        const response = await fetch('/api/merchello/checkout/shipping', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify({
                                selections: selectionsPayload
                            })
                        });

                        if (!response.ok) {
                            throw new Error(`HTTP ${response.status}`);
                        }

                        const result = await response.json();

                        if (result.success) {
                            this.announce('Shipping saved. Redirecting to payment.');
                            window.location.href = '/checkout/payment';
                        } else {
                            this.errorMessage = result.message || 'Failed to save shipping selections.';
                            if (result.errors) {
                                const errorMessages = Object.values(result.errors).join(' ');
                                if (errorMessages) {
                                    this.errorMessage = errorMessages;
                                }
                            }
                            this.announce(this.errorMessage);
                        }
                    } catch (error) {
                        console.error('Failed to save shipping:', error);
                        this.errorMessage = 'An error occurred. Please try again.';
                        this.announce(this.errorMessage);
                    } finally {
                        this.isSubmitting = false;
                    }
                }
            }
        }
    </script>
}
