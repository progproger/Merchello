@{
    var prefix = ViewData["Prefix"]?.ToString() ?? "address";
    var model = ViewData.Model as CheckoutViewModel;
    var countries = prefix == "billing"
        ? (model?.BillingCountries ?? [])
        : (model?.ShippingCountries ?? []);
    var requirePhone = model?.Settings?.RequirePhone ?? false;
    var compact = model?.IsSinglePageCheckout == true;
    var showRequired = ViewData["ShowRequired"] as bool? ?? false;
    var onBlurCallback = ViewData["OnBlurCallback"]?.ToString() ?? "";
    var hasBlurCallback = !string.IsNullOrEmpty(onBlurCallback);

    // Use checkout-input classes from CSS
    var inputClass = compact ? "checkout-input-compact w-full" : "checkout-input w-full";
    var selectClass = compact ? "checkout-input-compact w-full" : "checkout-input w-full";
    var labelClass = compact
        ? "block text-xs font-medium text-gray-700 mb-0.5"
        : "block text-sm font-medium text-gray-700 mb-1";
    var spaceClass = compact ? "space-y-2" : "space-y-4";
    var gapClass = compact ? "gap-2" : "gap-4";
    var gridClass = compact ? "grid grid-cols-3" : "grid grid-cols-1 md:grid-cols-3";
}

<div class="@spaceClass">
    <!-- Name -->
    <div>
        <label for="@(prefix)-name" class="@labelClass">
            Full name @if (showRequired) { <span class="text-red-500">*</span> }
        </label>
        <input type="text"
               id="@(prefix)-name"
               x-model="form.@(prefix).name"
               @if (prefix == "shipping") { <text>:required="!shippingSameAsBilling"</text> } else { <text>required</text> }
               autocomplete="@prefix name"
               @if (hasBlurCallback) { <text>@@blur="validateField('@(prefix).name'); @(onBlurCallback)"</text> }
               :class="errors['@(prefix).name'] ? 'checkout-input-error' : ''"
               class="@inputClass" />
        <p x-show="errors['@(prefix).name']" x-text="errors['@(prefix).name']" class="checkout-error" x-cloak></p>
    </div>

    <!-- Company (Optional) -->
    <div>
        <label for="@(prefix)-company" class="@labelClass">
            Company
        </label>
        <input type="text"
               id="@(prefix)-company"
               x-model="form.@(prefix).company"
               autocomplete="@prefix organization"
               class="@inputClass" />
    </div>

    <!-- Address Line 1 -->
    <div>
        <label for="@(prefix)-address1" class="@labelClass">
            Address @if (showRequired) { <span class="text-red-500">*</span> }
        </label>
        <input type="text"
               id="@(prefix)-address1"
               x-model="form.@(prefix).address1"
               @if (prefix == "shipping") { <text>:required="!shippingSameAsBilling"</text> } else { <text>required</text> }
               autocomplete="@prefix address-line1"
               @if (hasBlurCallback) { <text>@@blur="validateField('@(prefix).address1'); @(onBlurCallback)"</text> }
               :class="errors['@(prefix).address1'] ? 'checkout-input-error' : ''"
               class="@inputClass" />
        <p x-show="errors['@(prefix).address1']" x-text="errors['@(prefix).address1']" class="checkout-error" x-cloak></p>
    </div>

    <!-- Address Line 2 (Optional) -->
    <div>
        <label for="@(prefix)-address2" class="sr-only">
            Address line 2
        </label>
        <input type="text"
               id="@(prefix)-address2"
               x-model="form.@(prefix).address2"
               autocomplete="@prefix address-line2"
               class="@inputClass" />
    </div>

    <!-- City, State, Postal Code -->
    <div class="@gridClass @gapClass">
        <div>
            <label for="@(prefix)-city" class="@labelClass">
                City @if (showRequired) { <span class="text-red-500">*</span> }
            </label>
            <input type="text"
                   id="@(prefix)-city"
                   x-model="form.@(prefix).city"
                   @if (prefix == "shipping") { <text>:required="!shippingSameAsBilling"</text> } else { <text>required</text> }
                   autocomplete="@prefix address-level2"
                   @if (hasBlurCallback) { <text>@@blur="validateField('@(prefix).city'); @(onBlurCallback)"</text> }
                   :class="errors['@(prefix).city'] ? 'checkout-input-error' : ''"
                   class="@inputClass" />
            <p x-show="errors['@(prefix).city']" x-text="errors['@(prefix).city']" class="checkout-error" x-cloak></p>
        </div>

        <div>
            <label for="@(prefix)-state" class="@labelClass">
                State/Region
            </label>
            <!-- Show dropdown if regions are loaded, otherwise show text input -->
            <template x-if="@(prefix)Regions.length > 0">
                <select id="@(prefix)-state"
                        x-model="form.@(prefix).stateCode"
                        @@change="on@(prefix.Substring(0,1).ToUpper())@(prefix.Substring(1))StateChange()@(hasBlurCallback ? $"; {onBlurCallback}" : "")"
                        autocomplete="@prefix address-level1"
                        class="@selectClass">
                    <option value="">Select...</option>
                    <template x-for="region in @(prefix)Regions" :key="region.code">
                        <option :value="region.code" x-text="region.name"></option>
                    </template>
                </select>
            </template>
            <template x-if="@(prefix)Regions.length === 0">
                <input type="text"
                       id="@(prefix)-state"
                       x-model="form.@(prefix).state"
                       autocomplete="@prefix address-level1"
                       class="@inputClass" />
            </template>
        </div>

        <div>
            <label for="@(prefix)-postal" class="@labelClass">
                Zip/Postcode @if (showRequired) { <span class="text-red-500">*</span> }
            </label>
            <input type="text"
                   id="@(prefix)-postal"
                   x-model="form.@(prefix).postalCode"
                   @if (prefix == "shipping") { <text>:required="!shippingSameAsBilling"</text> } else { <text>required</text> }
                   autocomplete="@prefix postal-code"
                   @if (hasBlurCallback) { <text>@@blur="validateField('@(prefix).postalCode'); @(onBlurCallback)"</text> }
                   :class="errors['@(prefix).postalCode'] ? 'checkout-input-error' : ''"
                   class="@inputClass" />
            <p x-show="errors['@(prefix).postalCode']" x-text="errors['@(prefix).postalCode']" class="checkout-error" x-cloak></p>
        </div>
    </div>

    <!-- Country -->
    <div>
        <label for="@(prefix)-country" class="@labelClass">
            Country @if (showRequired) { <span class="text-red-500">*</span> }
        </label>
        <select id="@(prefix)-country"
                x-model="form.@(prefix).countryCode"
                @@change="on@(prefix.Substring(0,1).ToUpper())@(prefix.Substring(1))CountryChange()"
                @if (prefix == "shipping") { <text>:required="!shippingSameAsBilling"</text> } else { <text>required</text> }
                autocomplete="@prefix country"
                :class="errors['@(prefix).countryCode'] ? 'checkout-input-error' : ''"
                class="@selectClass">
            <option value="">Select country...</option>
            @foreach (var country in countries)
            {
                <option value="@country.Code">@country.Name</option>
            }
        </select>
        <p x-show="errors['@(prefix).countryCode']" x-text="errors['@(prefix).countryCode']" class="checkout-error" x-cloak></p>
    </div>

    <!-- Phone -->
    <div>
        <label for="@(prefix)-phone" class="@labelClass">
            Phone @if (!requirePhone) { <span class="text-gray-400">(optional)</span> }
        </label>
        <input type="tel"
               id="@(prefix)-phone"
               x-model="form.@(prefix).phone"
               @if (requirePhone) { <text>required</text> }
               autocomplete="@prefix tel"
               @if (hasBlurCallback) { <text>@@blur="validateField('@(prefix).phone'); @(onBlurCallback)"</text> }
               :class="errors['@(prefix).phone'] ? 'checkout-input-error' : ''"
               class="@inputClass" />
        <p x-show="errors['@(prefix).phone']" x-text="errors['@(prefix).phone']" class="checkout-error" x-cloak></p>
    </div>
</div>
