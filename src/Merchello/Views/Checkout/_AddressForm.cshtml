@{
    var prefix = ViewData["Prefix"]?.ToString() ?? "address";
    var model = ViewData.Model as CheckoutViewModel;
    var countries = prefix == "billing"
        ? (model?.BillingCountries ?? [])
        : (model?.ShippingCountries ?? []);
    var requirePhone = model?.Settings?.RequirePhone ?? false;
}

<div class="space-y-4">
    <!-- Name -->
    <div>
        <label for="@(prefix)_name" class="block text-sm font-medium text-gray-700 mb-1">
            Full name
        </label>
        <input type="text"
               id="@(prefix)_name"
               name="@(prefix).name"
               x-model="form.@(prefix).name"
               required
               autocomplete="name"
               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent transition-colors"
               placeholder="John Doe" />
        <p x-show="errors['@(prefix).name']" x-text="errors['@(prefix).name']" class="mt-1 text-sm text-red-600" x-cloak></p>
    </div>

    <!-- Company (Optional) -->
    <div>
        <label for="@(prefix)_company" class="block text-sm font-medium text-gray-700 mb-1">
            Company <span class="text-gray-400">(optional)</span>
        </label>
        <input type="text"
               id="@(prefix)_company"
               name="@(prefix).company"
               x-model="form.@(prefix).company"
               autocomplete="organization"
               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent transition-colors"
               placeholder="Company name" />
    </div>

    <!-- Address Line 1 -->
    <div>
        <label for="@(prefix)_address1" class="block text-sm font-medium text-gray-700 mb-1">
            Address
        </label>
        <input type="text"
               id="@(prefix)_address1"
               name="@(prefix).address1"
               x-model="form.@(prefix).address1"
               required
               autocomplete="address-line1"
               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent transition-colors"
               placeholder="123 Main Street" />
        <p x-show="errors['@(prefix).address1']" x-text="errors['@(prefix).address1']" class="mt-1 text-sm text-red-600" x-cloak></p>
    </div>

    <!-- Address Line 2 (Optional) -->
    <div>
        <input type="text"
               id="@(prefix)_address2"
               name="@(prefix).address2"
               x-model="form.@(prefix).address2"
               autocomplete="address-line2"
               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent transition-colors"
               placeholder="Apt 4B" />
    </div>

    <!-- City, State, Postal Code -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
            <label for="@(prefix)_city" class="block text-sm font-medium text-gray-700 mb-1">
                City
            </label>
            <input type="text"
                   id="@(prefix)_city"
                   name="@(prefix).city"
                   x-model="form.@(prefix).city"
                   required
                   autocomplete="address-level2"
                   class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent transition-colors"
                   placeholder="London" />
            <p x-show="errors['@(prefix).city']" x-text="errors['@(prefix).city']" class="mt-1 text-sm text-red-600" x-cloak></p>
        </div>

        <div>
            <label for="@(prefix)_state" class="block text-sm font-medium text-gray-700 mb-1">
                State / County
            </label>
            <!-- Show dropdown if regions are loaded, otherwise show text input -->
            <template x-if="@(prefix)Regions && @(prefix)Regions.length > 0">
                <select id="@(prefix)_state"
                        name="@(prefix).stateCode"
                        x-model="form.@(prefix).stateCode"
                        @@change="form.@(prefix).state = @(prefix)Regions.find(r => r.code === form.@(prefix).stateCode)?.name || ''"
                        autocomplete="address-level1"
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent transition-colors bg-white">
                    <option value="">Select a region</option>
                    <template x-for="region in @(prefix)Regions" :key="region.code">
                        <option :value="region.code" x-text="region.name"></option>
                    </template>
                </select>
            </template>
            <template x-if="!@(prefix)Regions || @(prefix)Regions.length === 0">
                <input type="text"
                       id="@(prefix)_state"
                       name="@(prefix).state"
                       x-model="form.@(prefix).state"
                       autocomplete="address-level1"
                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent transition-colors"
                       placeholder="Greater London" />
            </template>
        </div>

        <div>
            <label for="@(prefix)_postalCode" class="block text-sm font-medium text-gray-700 mb-1">
                Postal code
            </label>
            <input type="text"
                   id="@(prefix)_postalCode"
                   name="@(prefix).postalCode"
                   x-model="form.@(prefix).postalCode"
                   required
                   autocomplete="postal-code"
                   class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent transition-colors"
                   placeholder="SW1A 1AA" />
            <p x-show="errors['@(prefix).postalCode']" x-text="errors['@(prefix).postalCode']" class="mt-1 text-sm text-red-600" x-cloak></p>
        </div>
    </div>

    <!-- Country -->
    <div>
        <label for="@(prefix)_country" class="block text-sm font-medium text-gray-700 mb-1">
            Country
        </label>
        <select id="@(prefix)_country"
                name="@(prefix).countryCode"
                x-model="form.@(prefix).countryCode"
                @@change="onCountryChange@(prefix.Substring(0,1).ToUpper())@(prefix.Substring(1))()"
                required
                autocomplete="country"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent transition-colors bg-white">
            <option value="">Select a country</option>
            @foreach (var country in countries)
            {
                <option value="@country.Code">@country.Name</option>
            }
        </select>
        <p x-show="errors['@(prefix).countryCode']" x-text="errors['@(prefix).countryCode']" class="mt-1 text-sm text-red-600" x-cloak></p>
    </div>

    <!-- Phone -->
    <div>
        <label for="@(prefix)_phone" class="block text-sm font-medium text-gray-700 mb-1">
            Phone @if (!requirePhone) { <span class="text-gray-400">(optional)</span> }
        </label>
        <input type="tel"
               id="@(prefix)_phone"
               name="@(prefix).phone"
               x-model="form.@(prefix).phone"
               @if (requirePhone) { <text>required</text> }
               autocomplete="tel"
               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-accent focus:border-accent transition-colors"
               placeholder="+44 123 456 7890" />
        <p x-show="errors['@(prefix).phone']" x-text="errors['@(prefix).phone']" class="mt-1 text-sm text-red-600" x-cloak></p>
    </div>
</div>
