@model Merchello.Models.PasswordResetViewModel
@using Merchello.Core.Checkout.Models
@inject Microsoft.Extensions.Options.IOptions<CheckoutSettings> CheckoutSettingsOptions
@{
    Layout = null;
    var settings = CheckoutSettingsOptions.Value;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Reset Password - @(settings.CompanyName ?? "Checkout")</title>

    <!-- Import map for ES module resolution -->
    <script type="importmap">
    {
        "imports": {
            "alpinejs": "https://cdn.jsdelivr.net/npm/alpinejs@3/dist/module.esm.js"
        }
    }
    </script>

    <!-- Alpine.js for interactivity -->
    <script type="module">
        import Alpine from 'alpinejs';
        window.Alpine = Alpine;
        Alpine.start();
    </script>

    <!-- Checkout styles -->
    <link rel="stylesheet" href="/css/checkout.css" />

    <style>
        :root {
            --color-primary: @settings.PrimaryColor;
            --color-accent: @settings.AccentColor;
            --color-error: @settings.ErrorColor;
            --font-heading: '@settings.HeadingFontFamily', system-ui, sans-serif;
            --font-body: '@settings.BodyFontFamily', system-ui, sans-serif;
        }

        [x-cloak] { display: none !important; }

        body {
            background-color: @settings.BackgroundColor;
            color: @settings.TextColor;
        }
    </style>
</head>
<body class="font-body antialiased min-h-screen">
    <!-- Header -->
    <header class="border-b border-gray-200 bg-white">
        <div class="max-w-md mx-auto px-4 py-4">
            <div class="flex items-center justify-center">
                @if (!string.IsNullOrEmpty(settings.LogoUrl))
                {
                    <a href="/" class="block">
                        <img src="@settings.LogoUrl"
                             alt="@(settings.CompanyName ?? "Store")"
                             style="max-width: @(settings.LogoMaxWidth)px;"
                             class="h-auto" />
                    </a>
                }
                else if (!string.IsNullOrEmpty(settings.CompanyName))
                {
                    <a href="/" class="font-heading text-xl font-semibold text-gray-900 hover:text-gray-700">
                        @settings.CompanyName
                    </a>
                }
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="py-12 px-4">
        <div class="max-w-md mx-auto" x-data="passwordReset()">
            <h1 class="font-heading text-2xl font-semibold text-center mb-6">Reset Your Password</h1>

            @if (!Model.TokenValid)
            {
                <!-- Invalid/expired token -->
                <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
                    <div class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-red-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        <div>
                            <p class="text-red-700 text-sm font-medium">Unable to reset password</p>
                            <p class="text-red-600 text-sm mt-1">@Model.ErrorMessage</p>
                        </div>
                    </div>
                </div>

                <div class="text-center space-y-4">
                    <p class="text-sm text-gray-600">
                        Reset links expire after 1 hour for security reasons.
                    </p>
                    <a href="/checkout" class="inline-block checkout-button-primary px-6 py-2">
                        Return to Checkout
                    </a>
                </div>
            }
            else
            {
                <!-- Valid token - show reset form -->
                <form x-on:submit.prevent="submitReset" class="space-y-4">
                    <!-- Success message -->
                    <div x-show="success" x-cloak class="bg-green-50 border border-green-200 rounded-lg p-4">
                        <div class="flex items-start gap-3">
                            <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            <div>
                                <p class="text-green-700 text-sm font-medium">Password reset successful!</p>
                                <p class="text-green-600 text-sm mt-1">
                                    Your password has been updated. You can now sign in with your new password.
                                </p>
                            </div>
                        </div>
                        <div class="mt-4 text-center">
                            <a href="/checkout" class="inline-block checkout-button-primary px-6 py-2">
                                Return to Checkout
                            </a>
                        </div>
                    </div>

                    <!-- Error message -->
                    <div x-show="error && !success" x-cloak class="bg-red-50 border border-red-200 rounded-lg p-4">
                        <p class="text-red-700 text-sm" x-text="error"></p>
                    </div>

                    <div x-show="!success">
                        <!-- New password field -->
                        <div>
                            <label for="newPassword" class="block text-sm font-medium text-gray-700 mb-1">
                                New Password <span class="text-red-500">*</span>
                            </label>
                            <input type="password"
                                   id="newPassword"
                                   name="newPassword"
                                   x-model="newPassword"
                                   required
                                   autocomplete="new-password"
                                   @@input.debounce.500ms="validatePassword()"
                                   class="checkout-input-compact w-full"
                                   :class="{'border-red-500': passwordErrors.length > 0, 'border-green-500': passwordValid && newPassword}" />

                            <!-- Validating indicator -->
                            <p x-show="validating" x-cloak class="text-xs text-gray-500 mt-1">
                                Checking password requirements...
                            </p>

                            <!-- Password validation errors -->
                            <template x-for="err in passwordErrors" :key="err">
                                <p class="text-xs text-red-600 mt-1" x-text="err"></p>
                            </template>

                            <!-- Password valid indicator -->
                            <p x-show="passwordValid && newPassword && !validating" x-cloak class="text-xs text-green-600 mt-1">
                                Password meets requirements
                            </p>
                        </div>

                        <!-- Confirm password field -->
                        <div class="mt-4">
                            <label for="confirmPassword" class="block text-sm font-medium text-gray-700 mb-1">
                                Confirm Password <span class="text-red-500">*</span>
                            </label>
                            <input type="password"
                                   id="confirmPassword"
                                   name="confirmPassword"
                                   x-model="confirmPassword"
                                   required
                                   autocomplete="new-password"
                                   class="checkout-input-compact w-full"
                                   :class="{'border-red-500': confirmError, 'border-green-500': !confirmError && confirmPassword && confirmPassword === newPassword}" />
                            <p x-show="confirmError" x-cloak class="text-xs text-red-600 mt-1" x-text="confirmError"></p>
                        </div>

                        <!-- Submit button -->
                        <button type="submit"
                                class="w-full checkout-button-primary mt-6"
                                :disabled="!canSubmit || submitting">
                            <span x-show="!submitting">Reset Password</span>
                            <span x-show="submitting" x-cloak class="flex items-center justify-center gap-2">
                                <svg class="animate-spin h-5 w-5" viewBox="0 0 24 24">
                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle>
                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                </svg>
                                <span>Resetting...</span>
                            </span>
                        </button>

                        <!-- Back link -->
                        <p class="text-center mt-4">
                            <a href="/checkout" class="text-sm text-accent hover:underline">
                                Back to checkout
                            </a>
                        </p>
                    </div>
                </form>
            }
        </div>
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-200 bg-gray-50 mt-auto">
        <div class="max-w-md mx-auto px-4 py-6 text-center">
            @if (!string.IsNullOrEmpty(settings.CompanyName))
            {
                <p class="text-xs text-gray-500">
                    &copy; @DateTime.Now.Year @settings.CompanyName. All rights reserved.
                </p>
            }
        </div>
    </footer>

    <script>
        function passwordReset() {
            return {
                email: '@Html.Raw(Model.Email.Replace("'", "\\'"))',
                token: '@Html.Raw(Model.Token.Replace("'", "\\'"))',
                newPassword: '',
                confirmPassword: '',
                passwordErrors: [],
                passwordValid: false,
                validating: false,
                submitting: false,
                success: false,
                error: '',

                get confirmError() {
                    if (this.confirmPassword && this.confirmPassword !== this.newPassword) {
                        return 'Passwords do not match';
                    }
                    return '';
                },

                get canSubmit() {
                    return this.passwordValid &&
                           this.confirmPassword === this.newPassword &&
                           this.newPassword.length > 0 &&
                           !this.submitting;
                },

                async validatePassword() {
                    if (!this.newPassword) {
                        this.passwordErrors = [];
                        this.passwordValid = false;
                        return;
                    }

                    this.validating = true;
                    try {
                        const response = await fetch('/api/merchello/checkout/validate-password', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ password: this.newPassword })
                        });
                        const data = await response.json();
                        this.passwordErrors = data.errors || [];
                        this.passwordValid = data.isValid;
                    } catch {
                        this.passwordErrors = ['Unable to validate password'];
                        this.passwordValid = false;
                    } finally {
                        this.validating = false;
                    }
                },

                async submitReset() {
                    if (!this.canSubmit) return;

                    this.submitting = true;
                    this.error = '';

                    try {
                        const response = await fetch('/api/merchello/checkout/reset-password', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                email: this.email,
                                token: this.token,
                                newPassword: this.newPassword
                            })
                        });

                        const data = await response.json();

                        if (data.success) {
                            this.success = true;
                        } else {
                            this.error = data.errorMessage || 'Unable to reset password.';
                            if (data.validationErrors && data.validationErrors.length > 0) {
                                this.passwordErrors = data.validationErrors;
                                this.passwordValid = false;
                            }
                        }
                    } catch {
                        this.error = 'An error occurred. Please try again.';
                    } finally {
                        this.submitting = false;
                    }
                }
            };
        }
    </script>
</body>
</html>
