@model CheckoutViewModel
@{
    Layout = "~/Views/Checkout/_Layout.cshtml";
    var confirmation = Model.Confirmation;
}

@if (confirmation == null)
{
    <!-- Order Not Found -->
    <div class="max-w-2xl mx-auto text-center">
        <div class="mb-6">
            <div class="inline-flex items-center justify-center w-20 h-20 bg-red-100 rounded-full">
                <svg class="w-10 h-10 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </div>
        </div>

        <h1 class="font-heading text-3xl font-semibold text-gray-900 mb-2">Order not found</h1>
        <p class="text-gray-600 mb-8">We couldn't find the order you're looking for. It may have expired or the link is invalid.</p>

        <a href="/"
           class="inline-block px-8 py-3 bg-primary text-white font-medium rounded-lg hover:opacity-90 focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-all">
            Continue Shopping
        </a>
    </div>
}
else
{
    <div class="max-w-2xl mx-auto text-center">
        <!-- Success Icon -->
        <div class="mb-6">
            <div class="inline-flex items-center justify-center w-20 h-20 bg-green-100 rounded-full">
                <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
            </div>
        </div>

        <!-- Thank You Message -->
        <h1 class="font-heading text-3xl font-semibold text-gray-900 mb-2">Thank you for your order!</h1>
        <p class="text-gray-600 mb-8">Your order has been confirmed and will be shipping soon.</p>

        <!-- Order Details Card -->
        <div class="bg-gray-50 rounded-lg border border-gray-200 p-6 text-left mb-8">
            <div class="flex items-center justify-between mb-4 pb-4 border-b border-gray-200">
                <div>
                    <p class="text-sm text-gray-500">Order number</p>
                    <p class="text-lg font-semibold text-gray-900">#@confirmation.InvoiceNumber</p>
                </div>
                <div class="text-right">
                    <p class="text-sm text-gray-500">Order date</p>
                    <p class="text-sm font-medium text-gray-900">@confirmation.OrderDate.ToString("MMMM d, yyyy")</p>
                </div>
            </div>

            <!-- Order Summary -->
            <div class="space-y-4 mb-6">
                <h3 class="font-medium text-gray-900">Order summary</h3>

                <!-- Line Items -->
                <div class="space-y-3">
                    @foreach (var item in confirmation.LineItems)
                    {
                        <div class="flex items-center gap-4">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.Name" class="w-12 h-12 object-cover rounded flex-shrink-0" />
                            }
                            else
                            {
                                <div class="w-12 h-12 bg-gray-200 rounded flex-shrink-0"></div>
                            }
                            <div class="flex-1">
                                <p class="text-sm font-medium text-gray-900">@item.Name</p>
                                <p class="text-sm text-gray-500">Qty: @item.Quantity</p>
                            </div>
                            <p class="text-sm font-medium text-gray-900">@item.FormattedLineTotal</p>
                        </div>
                    }
                </div>

                <!-- Totals -->
                <div class="border-t border-gray-200 pt-4 space-y-2 text-sm">
                    <div class="flex justify-between">
                        <span class="text-gray-600">Subtotal</span>
                        <span class="text-gray-900">@confirmation.FormattedSubTotal</span>
                    </div>
                    @if (confirmation.Discount > 0)
                    {
                        <div class="flex justify-between text-green-600">
                            <span>Discount</span>
                            <span>-@confirmation.FormattedDiscount</span>
                        </div>
                    }
                    <div class="flex justify-between">
                        <span class="text-gray-600">Shipping</span>
                        <span class="text-gray-900">@(confirmation.Shipping > 0 ? confirmation.FormattedShipping : "Free")</span>
                    </div>
                    @if (confirmation.Tax > 0)
                    {
                        <div class="flex justify-between">
                            <span class="text-gray-600">Tax</span>
                            <span class="text-gray-900">@confirmation.FormattedTax</span>
                        </div>
                    }
                    <div class="flex justify-between font-semibold text-base pt-2 border-t border-gray-200">
                        <span>Total</span>
                        <span>@confirmation.FormattedTotal</span>
                    </div>
                </div>
            </div>

            <!-- Shipping Information -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-4 border-t border-gray-200">
                <div>
                    <h4 class="text-sm font-medium text-gray-900 mb-2">Shipping address</h4>
                    <address class="text-sm text-gray-600 not-italic">
                        @if (!string.IsNullOrEmpty(confirmation.ShippingAddress.Name))
                        {
                            @confirmation.ShippingAddress.Name<br />
                        }
                        @if (!string.IsNullOrEmpty(confirmation.ShippingAddress.Company))
                        {
                            @confirmation.ShippingAddress.Company<br />
                        }
                        @if (!string.IsNullOrEmpty(confirmation.ShippingAddress.Address1))
                        {
                            @confirmation.ShippingAddress.Address1<br />
                        }
                        @if (!string.IsNullOrEmpty(confirmation.ShippingAddress.Address2))
                        {
                            @confirmation.ShippingAddress.Address2<br />
                        }
                        @{
                            var cityLine = new List<string>();
                            if (!string.IsNullOrEmpty(confirmation.ShippingAddress.City)) cityLine.Add(confirmation.ShippingAddress.City);
                            if (!string.IsNullOrEmpty(confirmation.ShippingAddress.State)) cityLine.Add(confirmation.ShippingAddress.State);
                            if (!string.IsNullOrEmpty(confirmation.ShippingAddress.PostalCode)) cityLine.Add(confirmation.ShippingAddress.PostalCode);
                        }
                        @if (cityLine.Count > 0)
                        {
                            @string.Join(", ", cityLine)<br />
                        }
                        @if (!string.IsNullOrEmpty(confirmation.ShippingAddress.Country))
                        {
                            @confirmation.ShippingAddress.Country
                        }
                    </address>
                </div>
                <div>
                    <h4 class="text-sm font-medium text-gray-900 mb-2">Shipping method</h4>
                    @if (confirmation.Shipments.Count > 0)
                    {
                        @foreach (var shipment in confirmation.Shipments)
                        {
                            <p class="text-sm text-gray-600">
                                @shipment.ShippingMethodName
                                @if (!string.IsNullOrEmpty(shipment.DeliveryEstimate))
                                {
                                    <span class="text-gray-500">(@shipment.DeliveryEstimate)</span>
                                }
                            </p>
                        }
                    }
                    else
                    {
                        <p class="text-sm text-gray-600">Standard Shipping</p>
                    }
                </div>
            </div>
        </div>

        <!-- Email Confirmation Notice -->
        @if (!string.IsNullOrEmpty(confirmation.CustomerEmail))
        {
            <div class="bg-blue-50 rounded-lg border border-blue-200 p-4 mb-8">
                <div class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                    </svg>
                    <p class="text-sm text-blue-800">
                        A confirmation email has been sent to <strong>@confirmation.CustomerEmail</strong> with your order details and tracking information.
                    </p>
                </div>
            </div>
        }

        <!-- Continue Shopping Button -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a href="/"
               class="w-full sm:w-auto px-8 py-3 bg-primary text-white font-medium rounded-lg hover:opacity-90 focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-all text-center">
                Continue Shopping
            </a>

            @if (!string.IsNullOrEmpty(Model.Settings.SupportEmail))
            {
                <a href="mailto:@Model.Settings.SupportEmail"
                   class="w-full sm:w-auto px-8 py-3 border border-gray-300 text-gray-700 font-medium rounded-lg hover:bg-gray-50 focus:ring-2 focus:ring-offset-2 focus:ring-gray-300 transition-all text-center">
                    Need Help?
                </a>
            }
        </div>
    </div>
}
