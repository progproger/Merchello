@model CheckoutViewModel
@{
    Layout = "~/Views/Checkout/_Layout.cshtml";
}

<div class="grid grid-cols-1 lg:grid-cols-2 gap-0" x-data="checkoutInformation()">
    <!-- Screen reader announcements -->
    <div aria-live="polite" aria-atomic="true" class="sr-only" x-text="announcement"></div>

    <!-- Left Column: Form -->
    <div class="pt-8 lg:pr-12 pb-24 lg:pb-8">
        <h1 class="font-heading text-xl font-normal mb-6">Contact</h1>

        @if (Model.Settings.ShowExpressCheckout)
        {
            @await Html.PartialAsync("~/Views/Checkout/_ExpressCheckout.cshtml")
        }

        <!-- Contact Form -->
        <form x-on:submit.prevent="submitForm" class="space-y-6" :aria-busy="isSubmitting">
            <!-- General Error Message -->
            <div x-show="generalError" x-cloak role="alert" class="p-4 bg-red-50 border border-red-200 rounded-lg text-red-700">
                <p x-text="generalError"></p>
            </div>

            <!-- Email -->
            <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-1">
                    Email address <span class="text-red-500" aria-hidden="true">*</span>
                </label>
                <input type="email"
                       id="email"
                       name="email"
                       x-model="form.email"
                       required
                       autocomplete="email"
                       :aria-invalid="errors.email ? 'true' : 'false'"
                       :aria-describedby="errors.email ? 'email-error' : null"
                       :class="errors.email ? 'border-error focus:ring-error focus:border-error' : 'border-gray-300 focus:ring-accent focus:border-accent'"
                       class="w-full px-4 py-3 border rounded-lg focus:ring-2 transition-colors focus-visible:outline-none"
                       placeholder="you@example.com" />
                <p x-show="errors.email" x-cloak id="email-error" role="alert" class="text-error text-sm mt-1" x-text="errors.email"></p>
            </div>

            <!-- Billing Address Section -->
            <div class="mt-8 pt-8 border-t border-gray-200">
                <h2 class="font-heading text-xl font-normal mb-4">Billing address</h2>
                @{ ViewData["Prefix"] = "billing"; }
                @await Html.PartialAsync("~/Views/Checkout/_AddressForm.cshtml")
            </div>

            <!-- Shipping Address Section -->
            <div class="mt-8 pt-8 border-t border-gray-200">
                <h2 class="font-heading text-xl font-normal mb-4">Shipping address</h2>

                <label class="inline-flex items-center gap-3 mb-4 cursor-pointer checkout-touch-target">
                    <span class="checkout-checkbox-wrapper">
                        <input type="checkbox"
                               id="same-as-billing"
                               x-model="sameAsBilling"
                               @((Model.Session?.ShippingSameAsBilling ?? true) ? "checked" : "")
                               class="w-5 h-5 rounded border-gray-300 text-accent focus:ring-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2" />
                    </span>
                    <span class="text-sm text-gray-700">Same as billing address</span>
                </label>

                <div x-show="!sameAsBilling" x-cloak x-transition>
                    @{ ViewData["Prefix"] = "shipping"; }
                    @await Html.PartialAsync("~/Views/Checkout/_AddressForm.cshtml")
                </div>
            </div>

            <!-- Continue Button (Desktop) -->
            <div class="mt-8 hidden lg:flex justify-end">
                <button type="submit"
                        class="checkout-button-primary"
                        :disabled="isSubmitting"
                        :aria-busy="isSubmitting">
                    <span x-show="!isSubmitting">Continue to Shipping</span>
                    <span x-show="isSubmitting" x-cloak class="flex items-center gap-2">
                        <svg class="animate-spin h-5 w-5" aria-hidden="true" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                        <span>Processing...</span>
                    </span>
                </button>
            </div>
        </form>
    </div>

    <!-- Right Column: Order Summary -->
    <div class="relative lg:border-l lg:border-gray-200">
        <!-- Background extending to viewport edge -->
        <div class="hidden lg:block absolute inset-y-0 left-0 w-[200vw] bg-[#fafafa] -z-10"></div>
        <div class="lg:pl-8 lg:pt-8 lg:pr-8">
            @await Html.PartialAsync("~/Views/Checkout/_OrderSummary.cshtml")
        </div>
    </div>

    <!-- Mobile Sticky Action Bar -->
    <div class="checkout-sticky-actions lg:hidden">
        <button type="button"
                @@click="submitForm"
                class="w-full checkout-button-primary"
                :disabled="isSubmitting"
                :aria-busy="isSubmitting">
            <span x-show="!isSubmitting">Continue to Shipping</span>
            <span x-show="isSubmitting" x-cloak class="flex items-center justify-center gap-2">
                <svg class="animate-spin h-5 w-5" aria-hidden="true" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <span>Processing...</span>
            </span>
        </button>
    </div>
</div>

@section Scripts {
    <script>
        function checkoutInformation() {
            return {
                form: {
                    email: '@(Model.Basket?.BillingAddress?.Email ?? "")',
                    billing: {
                        name: '@(Model.Basket?.BillingAddress?.Name ?? "")',
                        company: '@(Model.Basket?.BillingAddress?.Company ?? "")',
                        address1: '@(Model.Basket?.BillingAddress?.AddressOne ?? "")',
                        address2: '@(Model.Basket?.BillingAddress?.AddressTwo ?? "")',
                        city: '@(Model.Basket?.BillingAddress?.TownCity ?? "")',
                        state: '@(Model.Basket?.BillingAddress?.CountyState?.Name ?? "")',
                        stateCode: '@(Model.Basket?.BillingAddress?.CountyState?.RegionCode ?? "")',
                        postalCode: '@(Model.Basket?.BillingAddress?.PostalCode ?? "")',
                        country: '@(Model.Basket?.BillingAddress?.Country ?? "")',
                        countryCode: '@(Model.Basket?.BillingAddress?.CountryCode ?? "")',
                        phone: '@(Model.Basket?.BillingAddress?.Phone ?? "")'
                    },
                    shipping: {
                        name: '@(Model.Basket?.ShippingAddress?.Name ?? "")',
                        company: '@(Model.Basket?.ShippingAddress?.Company ?? "")',
                        address1: '@(Model.Basket?.ShippingAddress?.AddressOne ?? "")',
                        address2: '@(Model.Basket?.ShippingAddress?.AddressTwo ?? "")',
                        city: '@(Model.Basket?.ShippingAddress?.TownCity ?? "")',
                        state: '@(Model.Basket?.ShippingAddress?.CountyState?.Name ?? "")',
                        stateCode: '@(Model.Basket?.ShippingAddress?.CountyState?.RegionCode ?? "")',
                        postalCode: '@(Model.Basket?.ShippingAddress?.PostalCode ?? "")',
                        country: '@(Model.Basket?.ShippingAddress?.Country ?? "")',
                        countryCode: '@(Model.Basket?.ShippingAddress?.CountryCode ?? "")',
                        phone: '@(Model.Basket?.ShippingAddress?.Phone ?? "")'
                    }
                },
                sameAsBilling: @((Model.Session?.ShippingSameAsBilling ?? true).ToString().ToLower()),
                isSubmitting: false,
                errors: {},
                generalError: '',
                billingRegions: [],
                shippingRegions: [],
                announcement: '',
                _debounceTimers: {},

                async init() {
                    // Load regions for pre-selected countries
                    if (this.form.billing.countryCode) {
                        await this.loadRegions('billing', this.form.billing.countryCode);
                    }
                    if (this.form.shipping.countryCode) {
                        await this.loadRegions('shipping', this.form.shipping.countryCode);
                    }
                },

                // Debounce helper to prevent rapid API calls
                debounce(key, fn, delay = 300) {
                    if (this._debounceTimers[key]) {
                        clearTimeout(this._debounceTimers[key]);
                    }
                    this._debounceTimers[key] = setTimeout(fn, delay);
                },

                // Announce message to screen readers
                announce(message) {
                    this.announcement = '';
                    // Small delay to ensure screen reader picks up change
                    setTimeout(() => {
                        this.announcement = message;
                    }, 100);
                },

                async loadRegions(addressType, countryCode) {
                    if (!countryCode) {
                        if (addressType === 'billing') {
                            this.billingRegions = [];
                        } else {
                            this.shippingRegions = [];
                        }
                        return;
                    }

                    try {
                        const response = await fetch(`/api/merchello/checkout/regions/${countryCode}`);
                        if (!response.ok) {
                            throw new Error(`HTTP ${response.status}`);
                        }
                        const regions = await response.json();
                        if (addressType === 'billing') {
                            this.billingRegions = regions;
                        } else {
                            this.shippingRegions = regions;
                        }
                    } catch (error) {
                        console.error('Failed to load regions:', error);
                    }
                },

                onCountryChangeBilling() {
                    this.form.billing.state = '';
                    this.form.billing.stateCode = '';
                    // Debounce region loading to prevent rapid API calls
                    this.debounce('billing-regions', () => {
                        this.loadRegions('billing', this.form.billing.countryCode);
                    });
                },

                onCountryChangeShipping() {
                    this.form.shipping.state = '';
                    this.form.shipping.stateCode = '';
                    // Debounce region loading to prevent rapid API calls
                    this.debounce('shipping-regions', () => {
                        this.loadRegions('shipping', this.form.shipping.countryCode);
                    });
                },

                validate() {
                    this.errors = {};
                    this.generalError = '';

                    // Email validation
                    if (!this.form.email) {
                        this.errors.email = 'Email is required.';
                    } else if (!/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(this.form.email)) {
                        this.errors.email = 'Please enter a valid email address.';
                    }

                    // Billing address validation
                    if (!this.form.billing.name) this.errors['billing.name'] = 'Name is required.';
                    if (!this.form.billing.address1) this.errors['billing.address1'] = 'Address is required.';
                    if (!this.form.billing.city) this.errors['billing.city'] = 'City is required.';
                    if (!this.form.billing.countryCode) this.errors['billing.countryCode'] = 'Country is required.';
                    if (!this.form.billing.postalCode) this.errors['billing.postalCode'] = 'Postal code is required.';

                    // Shipping address validation (if not same as billing)
                    if (!this.sameAsBilling) {
                        if (!this.form.shipping.name) this.errors['shipping.name'] = 'Name is required.';
                        if (!this.form.shipping.address1) this.errors['shipping.address1'] = 'Address is required.';
                        if (!this.form.shipping.city) this.errors['shipping.city'] = 'City is required.';
                        if (!this.form.shipping.countryCode) this.errors['shipping.countryCode'] = 'Country is required.';
                        if (!this.form.shipping.postalCode) this.errors['shipping.postalCode'] = 'Postal code is required.';
                    }

                    return Object.keys(this.errors).length === 0;
                },

                async submitForm() {
                    if (!this.validate()) {
                        const errorCount = Object.keys(this.errors).length;
                        this.announce(`Form has ${errorCount} error${errorCount !== 1 ? 's' : ''}. Please correct and try again.`);
                        // Focus first error field
                        const firstErrorKey = Object.keys(this.errors)[0];
                        const firstErrorField = document.getElementById(firstErrorKey.replace('.', '-'));
                        if (firstErrorField) {
                            firstErrorField.focus();
                        }
                        return;
                    }

                    this.isSubmitting = true;
                    this.generalError = '';
                    this.announce('Saving your information...');

                    try {
                        const response = await fetch('/api/merchello/checkout/addresses', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                email: this.form.email,
                                billingAddress: this.form.billing,
                                shippingAddress: this.sameAsBilling ? null : this.form.shipping,
                                shippingSameAsBilling: this.sameAsBilling
                            })
                        });

                        if (!response.ok) {
                            throw new Error(`HTTP ${response.status}`);
                        }

                        const data = await response.json();

                        if (data.success) {
                            // Emit analytics event for contact completion
                            if (window.MerchelloCheckout) {
                                window.MerchelloCheckout.emit('checkout:contact_complete', {
                                    email: this.form.email
                                });
                            }
                            this.announce('Information saved. Redirecting to shipping.');
                            window.location.href = '/checkout/shipping';
                        } else {
                            if (data.errors) {
                                this.errors = data.errors;
                            }
                            this.generalError = data.message || 'Failed to save addresses. Please try again.';
                            this.announce(this.generalError);
                        }
                    } catch (error) {
                        console.error('Submission failed:', error);
                        this.generalError = 'An unexpected error occurred. Please try again.';
                        this.announce(this.generalError);
                    } finally {
                        this.isSubmitting = false;
                    }
                }
            }
        }
    </script>
}
