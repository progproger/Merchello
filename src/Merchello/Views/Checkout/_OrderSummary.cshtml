@using Merchello.Core.Accounting.Models
@using Merchello.Core.Accounting.Extensions
@using Merchello.Core.Checkout.Dtos
@using System.Linq
@inject Merchello.Core.Shared.Services.Interfaces.ICurrencyService CurrencyService
@{
    var model = ViewData.Model as CheckoutViewModel;
    var basket = model?.Basket;

    // Mode: "interactive" (default, checkout) or "readonly" (confirmation)
    var mode = ViewData["Mode"]?.ToString() ?? "interactive";
    var isReadonly = mode == "readonly";
    var confirmation = isReadonly ? ViewData["Confirmation"] as OrderConfirmationDto : null;

    // For interactive mode, use basket data; for readonly mode, use confirmation data
    var hasItems = isReadonly ? (confirmation?.LineItems?.Count > 0) : (model?.HasItems ?? false);
    var isSinglePage = !isReadonly && (model?.IsSinglePageCheckout ?? false);

    // Use display currency from view model (customer's selected currency)
    var displayCurrencySymbol = isReadonly
        ? confirmation?.DisplayCurrencySymbol ?? "£"
        : model?.DisplayCurrencySymbol ?? basket?.CurrencySymbol ?? "£";
    var displayCurrencyCode = isReadonly
        ? confirmation?.DisplayCurrencyCode ?? "GBP"
        : model?.DisplayCurrencyCode ?? basket?.Currency ?? "GBP";
    var exchangeRate = isReadonly ? 1m : (model?.ExchangeRate ?? 1m);
    var decimalPlaces = isReadonly ? 2 : (model?.CurrencyDecimalPlaces ?? 2);
    var numberFormat = $"N{decimalPlaces}";

    // For readonly mode, use pre-calculated display values from confirmation
    // For interactive mode, use pre-calculated display values from ViewModel (properly rounded via ICurrencyService)
    var displaySubTotal = isReadonly ? (confirmation?.DisplaySubTotal ?? 0) : (model?.DisplaySubTotal ?? 0);
    var displayDiscount = isReadonly ? (confirmation?.DisplayDiscount ?? 0) : (model?.DisplayDiscount ?? 0);
    var displayShipping = isReadonly ? (confirmation?.DisplayShipping ?? 0) : (model?.DisplayShipping ?? 0);
    var displayTax = isReadonly ? (confirmation?.DisplayTax ?? 0) : (model?.DisplayTax ?? 0);
    var displayTotal = isReadonly ? (confirmation?.DisplayTotal ?? 0) : (model?.DisplayTotal ?? 0);

    // Tax-inclusive display
    var displayPricesIncTax = isReadonly ? (confirmation?.DisplayPricesIncTax ?? false) : (model?.DisplayPricesIncTax ?? false);
    var taxInclusiveDisplaySubTotal = isReadonly
        ? (confirmation?.TaxInclusiveDisplaySubTotal ?? 0)
        : (model?.TaxInclusiveDisplaySubTotal ?? 0);
    var formattedTaxInclusiveDisplaySubTotal = isReadonly
        ? (confirmation?.FormattedTaxInclusiveDisplaySubTotal ?? "")
        : (model?.FormattedTaxInclusiveDisplaySubTotal ?? "");
    var taxIncludedMessage = isReadonly ? confirmation?.TaxIncludedMessage : model?.TaxIncludedMessage;

}

<div class="bg-[#fafafa] lg:bg-transparent" @Html.Raw(isReadonly ? "" : "x-data=\"orderSummary\"")>
    @if (!isReadonly)
    {
        <!-- Mobile Collapsed Header (visible on mobile, hidden on desktop) -->
        <button type="button"
                @@click="expanded = !expanded"
                :aria-expanded="expanded"
                aria-controls="order-summary-content"
                class="lg:hidden w-full p-4 flex items-center justify-between checkout-touch-target bg-[#fafafa] border-y border-gray-200">
            <div class="flex items-center gap-2">
                <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
                </svg>
                <span class="text-accent text-sm" x-text="expanded ? 'Hide order summary' : 'Show order summary'">Show order summary</span>
                <svg class="w-4 h-4 text-accent transition-transform"
                     :class="{ 'rotate-180': expanded }"
                     aria-hidden="true"
                     fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
            </div>
            @if (isSinglePage)
            {
                <span class="text-lg font-semibold text-gray-900" x-text="formatCurrency(total)"></span>
            }
            else
            {
                <span class="text-lg font-semibold text-gray-900">@(basket != null ? $"{displayCurrencySymbol}{displayTotal.ToString(numberFormat)}" : "--")</span>
            }
        </button>
    }

    <!-- Order Summary Content -->
    <div id="order-summary-content"
         class="@(isReadonly ? "block" : "hidden lg:block")"
         @Html.Raw(isReadonly ? "" : ":class=\"{ 'block': expanded }\"")>
        <div class="p-4 @(isReadonly ? "lg:p-0" : "pb-24 lg:p-0 lg:pb-0 lg:pt-0 lg:mt-0")">

    @if (!hasItems)
    {
        <!-- Empty cart message -->
        <div class="text-center py-8">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
            </svg>
            <p class="mt-2 text-sm text-gray-500">Your cart is empty</p>
            <a href="/" class="mt-4 inline-block text-accent hover:underline text-sm">Continue shopping</a>
        </div>
    }
    else
    {
        <!-- Line Items (Shopify style with quantity badges) -->
        <div class="space-y-4 pb-6">
            @if (isReadonly && confirmation?.LineItems != null)
            {
                @foreach (var item in confirmation.LineItems.Where(li => li.LineItemType == LineItemType.Product || li.LineItemType == LineItemType.Custom))
                {
                    var itemAddons = confirmation.LineItems
                        .Where(li => li.LineItemType == LineItemType.Addon &&
                                     ((li.ParentLineItemId == item.Id.ToString()) ||
                                      (string.IsNullOrEmpty(li.ParentLineItemId) && li.DependantLineItemSku == item.Sku)))
                        .ToList();

                    <div class="flex gap-4 items-start">
                        <!-- Product Image with Quantity Badge -->
                        <div class="relative flex-shrink-0">
                            <div class="w-16 h-16 bg-white rounded-lg border border-gray-200 flex items-center justify-center overflow-hidden">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl"
                                         alt="@item.ProductRootName"
                                         class="w-full h-full object-cover" />
                                }
                                else
                                {
                                    <svg class="w-8 h-8 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                    </svg>
                                }
                            </div>
                            <!-- Quantity Badge -->
                            <span class="absolute -top-2 -right-2 w-5 h-5 bg-[rgba(114,114,114,0.9)] text-white text-xs font-medium rounded-full flex items-center justify-center">
                                @item.Quantity
                            </span>
                        </div>
                        <!-- Product Details -->
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-medium text-gray-900 leading-tight">@item.ProductRootName</p>
                            @if (item.SelectedOptions.Count > 0)
                            {
                                @foreach (var opt in item.SelectedOptions)
                                {
                                    <p class="text-xs text-gray-500 mt-0.5">@opt.OptionName: @opt.ValueName</p>
                                }
                            }
                            @if (itemAddons.Count > 0)
                            {
                                @foreach (var addon in itemAddons)
                                {
                                    var addonDisplayUnitAmount = addon.DisplayUnitPrice;
                                    if (displayPricesIncTax && addon.IsTaxable && addon.TaxRate > 0)
                                    {
                                        addonDisplayUnitAmount = addon.DisplayUnitPrice * (1 + (addon.TaxRate / 100m));
                                    }
                                    var addonName = string.IsNullOrWhiteSpace(addon.Name) ? addon.ProductRootName : addon.Name;
                                    <p class="text-xs text-gray-500 mt-1">
                                        @addonName
                                        <span class="ml-1">(+@displayCurrencySymbol@addonDisplayUnitAmount.ToString(numberFormat))</span>
                                    </p>
                                }
                            }
                        </div>
                        <!-- Price: apply tax-inclusive when enabled -->
                        <div class="text-sm font-medium text-gray-900">
                            @{
                                var hasAddonInclusiveValue = item.DisplayLineTotalWithAddons != 0m || itemAddons.Count == 0;
                                var confirmLineAmount = hasAddonInclusiveValue
                                    ? item.DisplayLineTotalWithAddons
                                    : item.DisplayLineTotal;
                                if (displayPricesIncTax)
                                {
                                    confirmLineAmount = item.DisplayLineTotal;
                                    if (item.IsTaxable && item.TaxRate > 0)
                                    {
                                        confirmLineAmount *= 1 + (item.TaxRate / 100m);
                                    }

                                    foreach (var addon in itemAddons)
                                    {
                                        var addonLineAmount = addon.DisplayLineTotal;
                                        if (addon.IsTaxable && addon.TaxRate > 0)
                                        {
                                            addonLineAmount *= 1 + (addon.TaxRate / 100m);
                                        }

                                        confirmLineAmount += addonLineAmount;
                                    }
                                }
                            }
                            @displayCurrencySymbol@confirmLineAmount.ToString(numberFormat)
                        </div>
                    </div>
                }
            }
            else if (isSinglePage)
            {
                <template x-for="item in (($store.checkout?.basketLineItems ?? []).filter(li => li && (li.lineItemType === 'Product' || li.lineItemType === 'Custom' || li.lineItemType === 0 || li.lineItemType === 1)))" :key="item.id">
                    <div class="flex gap-4 items-start">
                        <!-- Product Image with Quantity Badge -->
                        <div class="relative flex-shrink-0">
                            <div class="w-16 h-16 bg-white rounded-lg border border-gray-200 flex items-center justify-center overflow-hidden">
                                <template x-if="item.imageUrl">
                                    <img :src="item.imageUrl"
                                         :alt="item.productRootName || item.name"
                                         class="w-full h-full object-cover" />
                                </template>
                                <template x-if="!item.imageUrl">
                                    <svg class="w-8 h-8 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                    </svg>
                                </template>
                            </div>
                            <span class="absolute -top-2 -right-2 w-5 h-5 bg-[rgba(114,114,114,0.9)] text-white text-xs font-medium rounded-full flex items-center justify-center"
                                  x-text="item.quantity"></span>
                        </div>

                        <!-- Product Details -->
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-medium text-gray-900 leading-tight" x-text="item.productRootName || item.name"></p>

                            <template x-if="item.selectedOptions?.length > 0">
                                <div>
                                    <template x-for="opt in item.selectedOptions"
                                              :key="item.id + '-' + opt.optionName + '-' + opt.valueName">
                                        <p class="text-xs text-gray-500 mt-0.5" x-text="opt.optionName + ': ' + opt.valueName"></p>
                                    </template>
                                </div>
                            </template>

                            <template x-if="(($store.checkout?.basketLineItems ?? []).filter(li => li && (li.lineItemType === 'Addon' || li.lineItemType === 4) && ((li.parentLineItemId && li.parentLineItemId === item.id) || (!li.parentLineItemId && li.dependantLineItemSku === item.sku)))).length > 0">
                                <div>
                                    <template x-for="addon in (($store.checkout?.basketLineItems ?? []).filter(li => li && (li.lineItemType === 'Addon' || li.lineItemType === 4) && ((li.parentLineItemId && li.parentLineItemId === item.id) || (!li.parentLineItemId && li.dependantLineItemSku === item.sku))))" :key="addon.id">
                                        <p class="text-xs text-gray-500 mt-1">
                                            <span x-text="addon.name || addon.productRootName"></span>
                                            <span class="ml-1" x-text="'(+' + (addon.formattedDisplayUnitPriceWithAddons || addon.formattedDisplayUnitPrice || formatAddonUnitPrice(addon)) + ')'"></span>
                                        </p>
                                    </template>
                                </div>
                            </template>
                        </div>

                        <div class="text-sm font-medium text-gray-900"
                             x-text="item.formattedDisplayLineTotalWithAddons || item.formattedDisplayLineTotal || formatLineItemTotal(item)"></div>
                    </div>
                </template>
            }
            else if (basket?.LineItems != null)
            {
                @foreach (var item in basket.LineItems.Where(li => li.LineItemType == LineItemType.Product || li.LineItemType == LineItemType.Custom))
                {
                    var itemAddons = basket.LineItems
                        .Where(li => li.LineItemType == LineItemType.Addon &&
                                     (li.GetParentLineItemId() == item.Id ||
                                      (!li.GetParentLineItemId().HasValue && li.DependantLineItemSku == item.Sku)))
                        .ToList();

                    <div class="flex gap-4 items-start">
                        <!-- Product Image with Quantity Badge -->
                        <div class="relative flex-shrink-0">
                            <div class="w-16 h-16 bg-white rounded-lg border border-gray-200 flex items-center justify-center overflow-hidden">
                                @if (!string.IsNullOrEmpty(item.ExtendedData?.GetValueOrDefault("ImageUrl")?.ToString()))
                                {
                                    <img src="@item.ExtendedData["ImageUrl"]"
                                         alt="@item.Name"
                                         class="w-full h-full object-cover" />
                                }
                                else
                                {
                                    <svg class="w-8 h-8 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                    </svg>
                                }
                            </div>
                            <!-- Quantity Badge -->
                            <span class="absolute -top-2 -right-2 w-5 h-5 bg-[rgba(114,114,114,0.9)] text-white text-xs font-medium rounded-full flex items-center justify-center">
                                @item.Quantity
                            </span>
                        </div>
                        <!-- Product Details -->
                        <div class="flex-1 min-w-0">
                            <p class="text-sm font-medium text-gray-900 leading-tight">@item.GetProductRootName()</p>
                            @{
                                var options = item.GetSelectedOptions();
                            }
                            @if (options.Count > 0)
                            {
                                @foreach (var opt in options)
                                {
                                    <p class="text-xs text-gray-500 mt-0.5">@opt.OptionName: @opt.ValueName</p>
                                }
                            }
                            @if (itemAddons.Count > 0)
                            {
                                @foreach (var addon in itemAddons)
                                {
                                    var addonLineAmount = addon.Amount;
                                    if (displayPricesIncTax && addon.IsTaxable && addon.TaxRate > 0)
                                    {
                                        addonLineAmount *= (1 + (addon.TaxRate / 100m));
                                    }
                                    var addonDisplayUnitAmount = CurrencyService.Round(addonLineAmount * exchangeRate, displayCurrencyCode);
                                    <p class="text-xs text-gray-500 mt-1">
                                        @addon.Name
                                        <span class="ml-1">(+@displayCurrencySymbol@addonDisplayUnitAmount.ToString(numberFormat))</span>
                                    </p>
                                }
                            }
                        </div>
                        <!-- Price: apply tax-inclusive when enabled -->
                        <div class="text-sm font-medium text-gray-900">
                            @{
                                var lineAmount = item.Amount * item.Quantity;
                                if (displayPricesIncTax && item.IsTaxable && item.TaxRate > 0)
                                {
                                    lineAmount *= (1 + (item.TaxRate / 100m));
                                }

                                var addonDisplayLineAmount = itemAddons.Sum(addon =>
                                {
                                    var addonAmount = addon.Amount * addon.Quantity;
                                    if (displayPricesIncTax && addon.IsTaxable && addon.TaxRate > 0)
                                    {
                                        addonAmount *= (1 + (addon.TaxRate / 100m));
                                    }

                                    return CurrencyService.Round(addonAmount * exchangeRate, displayCurrencyCode);
                                });
                                var displayLineAmount = CurrencyService.Round(lineAmount * exchangeRate, displayCurrencyCode) + addonDisplayLineAmount;
                            }
                            @displayCurrencySymbol@displayLineAmount.ToString(numberFormat)
                        </div>
                    </div>
                }
            }
        </div>

        @if (!isReadonly && model?.ShowDiscountCode == true)
        {
            <!-- Discount Code Input (Shopify style with border) - only for interactive mode -->
            <div class="pb-6">
                <div class="flex gap-2">
                    <div class="flex-1">
                        <input type="text"
                               x-model="discountCode"
                               placeholder="Discount code"
                               @@keydown.enter.prevent="applyDiscount()"
                               :disabled="applyingDiscount"
                               class="w-full px-4 py-3 bg-white border border-gray-200 rounded text-sm
                                      focus:ring-1 focus:ring-gray-400 focus:border-gray-400 focus:outline-none
                                      transition-colors disabled:bg-gray-50 disabled:text-gray-500
                                      placeholder:text-gray-400" />
                    </div>
                    <button type="button"
                            @@click="applyDiscount()"
                            :disabled="!discountCode.trim() || applyingDiscount"
                            class="px-5 py-3 bg-gray-100 hover:bg-gray-200 border border-gray-200 text-gray-600 text-sm font-medium rounded
                                   transition-colors disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-gray-100">
                        <span x-show="!applyingDiscount">Apply</span>
                        <span x-show="applyingDiscount" x-cloak>
                            <svg class="animate-spin h-4 w-4" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                        </span>
                    </button>
                </div>
                <p x-show="discountError" x-cloak x-text="discountError" role="alert" aria-live="polite" aria-atomic="true" class="text-sm text-red-600 mt-2"></p>
                <p x-show="discountSuccess" x-cloak x-text="discountSuccess" role="status" aria-live="polite" aria-atomic="true" class="text-sm text-green-600 mt-2"></p>
            </div>
        }

        <!-- Applied Discounts - reactive Alpine template for interactive mode -->
        @if (!isReadonly)
        {
            <template x-if="$store.checkout?.appliedDiscounts?.length > 0">
                <div class="pb-4 space-y-2">
                    <template x-for="discount in $store.checkout.appliedDiscounts" :key="discount.id">
                        <div class="flex items-center gap-2 p-2 bg-gray-100 rounded-md">
                            <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                            </svg>
                            <span class="flex-1 text-sm text-gray-700" x-text="discount.code || discount.name"></span>
                            <button type="button"
                                    @@click="removeDiscount(discount.id)"
                                    :disabled="removingDiscount === discount.id"
                                    class="p-1 text-gray-400 hover:text-gray-600 disabled:opacity-50"
                                    aria-label="Remove discount">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                </svg>
                            </button>
                        </div>
                    </template>
                </div>
            </template>
        }

        <!-- Totals (Shopify style) -->
        <div class="border-t border-gray-200 pt-4 space-y-2">
            <!-- Subtotal: show tax-inclusive when enabled -->
            <div class="flex justify-between text-sm">
                <span class="text-gray-600">Subtotal</span>
                @if (isReadonly)
                {
                    @if (displayPricesIncTax)
                    {
                        <span class="text-gray-900 font-medium">@formattedTaxInclusiveDisplaySubTotal</span>
                    }
                    else
                    {
                        <span class="text-gray-900 font-medium">@confirmation?.FormattedDisplaySubTotal</span>
                    }
                }
                else if (isSinglePage)
                {
                    <!-- For single-page checkout, Alpine.js handles tax-inclusive display -->
                    <span class="text-gray-900 font-medium"
                          x-text="displayPricesIncTax ? formattedTaxInclusiveDisplaySubTotal : formatCurrency(subtotal)"></span>
                }
                else
                {
                    @if (displayPricesIncTax)
                    {
                        <span class="text-gray-900 font-medium">@(basket != null ? $"{displayCurrencySymbol}{taxInclusiveDisplaySubTotal.ToString(numberFormat)}" : "--")</span>
                    }
                    else
                    {
                        <span class="text-gray-900 font-medium">@(basket != null ? $"{displayCurrencySymbol}{displaySubTotal.ToString(numberFormat)}" : "--")</span>
                    }
                }
            </div>

            <!-- Discount Total -->
            @if (isSinglePage)
            {
                <div class="flex justify-between text-sm"
                     x-show="discount > 0"
                     x-transition:enter="transition ease-out duration-200"
                     x-transition:enter-start="opacity-0"
                     x-transition:enter-end="opacity-100">
                    <span class="text-gray-600">Discount</span>
                    <span class="text-green-600 font-medium"
                          x-text="'-' + formatCurrency(discount)"></span>
                </div>
            }
            else if (displayDiscount > 0)
            {
                <div class="flex justify-between text-sm">
                    <span class="text-gray-600">Discount</span>
                    @if (isReadonly)
                    {
                        <span class="text-green-600 font-medium">-@confirmation?.FormattedDisplayDiscount</span>
                    }
                    else
                    {
                        <span class="text-green-600 font-medium">-@displayCurrencySymbol@displayDiscount.ToString("N2")</span>
                    }
                </div>
            }

            <!-- Shipping -->
            <div class="flex justify-between text-sm">
                <span class="text-gray-600">Shipping</span>
                @if (isReadonly)
                {
                    @if (displayShipping > 0)
                    {
                        <span class="text-gray-900 font-medium">@confirmation?.FormattedDisplayShipping</span>
                    }
                    else
                    {
                        <span class="text-green-600 font-medium">FREE</span>
                    }
                }
                else if (isSinglePage)
                {
                    <span x-show="shipping > 0"
                          x-transition:enter="transition ease-out duration-200"
                          x-transition:enter-start="opacity-0"
                          x-transition:enter-end="opacity-100"
                          class="text-gray-900 font-medium"
                          x-text="formatCurrency(shipping)"></span>
                    <span x-show="shipping === 0 && $store.checkout?.allShippingSelected()"
                          class="text-green-600 font-medium">FREE</span>
                    <span x-show="(shipping === 0 || shipping === undefined) && !$store.checkout?.allShippingSelected()"
                          class="text-gray-500 text-xs">Select shipping</span>
                }
                else if (basket?.Shipping > 0)
                {
                    <span class="text-gray-900 font-medium">@($"{displayCurrencySymbol}{displayShipping.ToString(numberFormat)}")</span>
                }
                else
                {
                    <span class="text-gray-500 text-xs">Calculated at next step</span>
                }
            </div>

            <!-- Tax: hide when tax-inclusive (tax is already included in subtotal) -->
            @if (isReadonly)
            {
                @if (!displayPricesIncTax)
                {
                    <div class="flex justify-between text-sm">
                        <span class="text-gray-600">Tax</span>
                        @if (displayTax > 0)
                        {
                            <span class="text-gray-900 font-medium">@confirmation?.FormattedDisplayTax</span>
                        }
                        else
                        {
                            <span class="text-gray-500 text-xs">Included in total</span>
                        }
                    </div>
                }
            }
            else if (isSinglePage)
            {
                <!-- For single-page checkout, Alpine.js controls visibility based on displayPricesIncTax -->
                <div class="flex justify-between text-sm" x-show="!displayPricesIncTax">
                    <span class="text-gray-600">Tax</span>
                    <template x-if="tax > 0">
                        <span class="text-gray-900 font-medium" x-text="formatCurrency(tax)"></span>
                    </template>
                    <template x-if="tax === 0">
                        <span class="text-gray-500 text-xs">Included in total</span>
                    </template>
                </div>
            }
            else if (!displayPricesIncTax)
            {
                <div class="flex justify-between text-sm">
                    <span class="text-gray-600">Tax</span>
                    @if (basket?.Tax > 0)
                    {
                        <span class="text-gray-900 font-medium">@($"{displayCurrencySymbol}{displayTax.ToString(numberFormat)}")</span>
                    }
                    else
                    {
                        <span class="text-gray-500 text-xs">Calculated at next step</span>
                    }
                </div>
            }

            <!-- Total -->
            <div class="flex justify-between items-baseline pt-4 mt-2 border-t border-gray-200">
                <span class="text-base text-gray-900">Total</span>
                <div class="text-right">
                    @if (isReadonly)
                    {
                        <span class="text-xl font-semibold text-gray-900">@confirmation?.FormattedDisplayTotal</span>
                    }
                    else if (isSinglePage)
                    {
                        <span class="text-xl font-semibold text-gray-900" x-text="formatCurrency(total)"></span>
                    }
                    else
                    {
                        <span class="text-xl font-semibold text-gray-900">@(basket != null ? $"{displayCurrencySymbol}{displayTotal.ToString(numberFormat)}" : "--")</span>
                    }
                </div>
            </div>

            <!-- Tax included message (Shopify style) -->
            @if (isReadonly && displayPricesIncTax && !string.IsNullOrEmpty(taxIncludedMessage))
            {
                <div class="text-gray-500 text-sm text-right mt-1">@taxIncludedMessage</div>
            }
            else if (isSinglePage)
            {
                <!-- For single-page checkout, Alpine.js controls visibility -->
                <div class="text-gray-500 text-sm text-right mt-1"
                     x-show="displayPricesIncTax && taxIncludedMessage"
                     x-text="taxIncludedMessage"></div>
            }
            else if (displayPricesIncTax && !string.IsNullOrEmpty(taxIncludedMessage))
            {
                <div class="text-gray-500 text-sm text-right mt-1">@taxIncludedMessage</div>
            }
        </div>

        @if (isReadonly && displayDiscount > 0)
        {
            <!-- Total Savings - only for readonly mode with discounts -->
            <div class="mt-4 pt-4 border-t border-gray-200">
                <div class="flex items-center gap-2 text-sm">
                    <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                    </svg>
                    <span class="font-medium text-gray-900">TOTAL SAVINGS</span>
                    <span class="ml-auto font-medium text-gray-900">@confirmation?.FormattedDisplayDiscount</span>
                </div>
            </div>
        }

    }

        </div><!-- /.p-4 padding wrapper -->
    </div><!-- /#order-summary-content -->
</div><!-- /.outer wrapper -->

@if (!isReadonly)
{
    <!-- orderSummary component is registered via index.js and reads totals from Alpine.store('checkout') -->
}
