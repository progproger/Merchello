@model Invoice
@using Merchello.Core.Accounting.Extensions
@{
    var currencySymbol = Model.CurrencySymbol ?? "\u00A3";
    var allLineItems = Model.Orders?
        .SelectMany(o => o.LineItems ?? Enumerable.Empty<LineItem>())
        .Where(li => li.LineItemType == Merchello.Core.Accounting.Models.LineItemType.Product
                  || li.LineItemType == Merchello.Core.Accounting.Models.LineItemType.Custom
                  || li.LineItemType == Merchello.Core.Accounting.Models.LineItemType.Addon)
        .ToList() ?? new List<LineItem>();
    var parentLineItems = allLineItems
        .Where(li => li.LineItemType == Merchello.Core.Accounting.Models.LineItemType.Product
                  || li.LineItemType == Merchello.Core.Accounting.Models.LineItemType.Custom)
        .ToList();
    var shippingTotal = Model.Orders?.Sum(o => o.ShippingCost) ?? 0;
}
<mj-section padding="10px 20px">
  <mj-column>
    <mj-text font-size="18px" font-weight="bold">Order Summary</mj-text>
  </mj-column>
</mj-section>

@if (parentLineItems.Count > 0)
{
<mj-section padding="0 20px">
  <mj-column>
    <mj-table>
      <tr style="border-bottom: 1px solid #ecedee;">
        <th style="padding: 10px 0; text-align: left;">Item</th>
        <th style="padding: 10px 0; text-align: center;">Qty</th>
        <th style="padding: 10px 0; text-align: right;">Price</th>
      </tr>
      @foreach (var item in parentLineItems)
      {
        var itemAddons = allLineItems
            .Where(li => li.IsAddonLinkedToParent(item))
            .ToList();
        var itemTotal = item.Amount * item.Quantity;
        var addonTotal = itemAddons.Sum(addon => addon.Amount * addon.Quantity);
        var displayLineTotal = itemTotal + addonTotal;
        var rootName = item.GetProductRootName();
        if (string.IsNullOrWhiteSpace(rootName))
        {
          rootName = item.Name ?? item.Sku;
        }
        var options = item.GetSelectedOptions();
        <tr style="border-bottom: 1px solid #ecedee;">
          <td style="padding: 10px 0;">
            <div style="font-weight: 500;">@rootName</div>
            @if (options.Count > 0)
            {
              <div style="font-size: 13px; color: #666;">
                @options.FormatOptionsCommaSeparated()
              </div>
            }
            <div style="font-size: 12px; color: #888;">SKU: @item.Sku</div>
            @if (itemAddons.Count > 0)
            {
              @foreach (var addon in itemAddons)
              {
                var addonAmountPrefix = addon.Amount >= 0 ? "+" : "-";
                var addonAmount = Math.Abs(addon.Amount);
                <div style="font-size: 12px; color: #666; margin-top: 3px;">
                  @(string.IsNullOrWhiteSpace(addon.Name) ? addon.Sku : addon.Name) (@addonAmountPrefix@currencySymbol@addonAmount.ToString("N2"))
                </div>
              }
            }
          </td>
          <td style="padding: 10px 0; text-align: center;">@item.Quantity</td>
          <td style="padding: 10px 0; text-align: right;">@currencySymbol@displayLineTotal.ToString("N2")</td>
        </tr>
      }
    </mj-table>
  </mj-column>
</mj-section>
}

<mj-section padding="10px 20px">
  <mj-column>
    <mj-table>
      <tr>
        <td style="padding: 5px 0;">Subtotal</td>
        <td style="padding: 5px 0; text-align: right;">@currencySymbol@Model.SubTotal.ToString("N2")</td>
      </tr>
      @if (Model.Tax > 0)
      {
      <tr>
        <td style="padding: 5px 0;">Tax</td>
        <td style="padding: 5px 0; text-align: right;">@currencySymbol@Model.Tax.ToString("N2")</td>
      </tr>
      }
      @if (shippingTotal > 0)
      {
      <tr>
        <td style="padding: 5px 0;">Shipping</td>
        <td style="padding: 5px 0; text-align: right;">@currencySymbol@shippingTotal.ToString("N2")</td>
      </tr>
      }
      @if (Model.Discount > 0)
      {
      <tr>
        <td style="padding: 5px 0;">Discount</td>
        <td style="padding: 5px 0; text-align: right;">-@currencySymbol@Model.Discount.ToString("N2")</td>
      </tr>
      }
      <tr style="border-top: 2px solid #333;">
        <td style="padding: 10px 0; font-weight: bold;">Total</td>
        <td style="padding: 10px 0; text-align: right; font-weight: bold; font-size: 18px;">@currencySymbol@Model.Total.ToString("N2")</td>
      </tr>
    </mj-table>
  </mj-column>
</mj-section>
