{
  "compilerOptions": {
    "target": "ES2020",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [ "ES2020", "DOM", "DOM.Iterable" ],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Path aliases */
    "baseUrl": ".",
    "paths": {
      "@abandoned-checkouts/*": [ "src/abandoned-checkouts/*" ],
      "@api/*": [ "src/api/*" ],
      "@analytics/*": [ "src/analytics/*" ],
      "@collections/*": [ "src/collections/*" ],
      "@customers/*": [ "src/customers/*" ],
      "@dashboards/*": [ "src/dashboards/*" ],
      "@discounts/*": [ "src/discounts/*" ],
      "@email/*": [ "src/email/*" ],
      "@entrypoints/*": [ "src/entrypoints/*" ],
      "@exchange-rate-providers/*": [ "src/exchange-rate-providers/*" ],
      "@filters/*": [ "src/filters/*" ],
      "@fulfilment-providers/*": [ "src/fulfilment-providers/*" ],
      "@marketing/*": [ "src/marketing/*" ],
      "@notifications/*": [ "src/notifications/*" ],
      "@orders/*": [ "src/orders/*" ],
      "@outstanding/*": [ "src/outstanding/*" ],
      "@payment-providers/*": [ "src/payment-providers/*" ],
      "@product-feed/*": [ "src/product-feed/*" ],
      "@product-types/*": [ "src/product-types/*" ],
      "@products/*": [ "src/products/*" ],
      "@providers/*": [ "src/providers/*" ],
      "@section/*": [ "src/section/*" ],
      "@settings/*": [ "src/settings/*" ],
      "@shared/*": [ "src/shared/*" ],
      "@shipping/*": [ "src/shipping/*" ],
      "@suppliers/*": [ "src/suppliers/*" ],
      "@tax/*": [ "src/tax/*" ],
      "@tree/*": [ "src/tree/*" ],
      "@warehouses/*": [ "src/warehouses/*" ],
      "@webhooks/*": [ "src/webhooks/*" ],
      "@test-utils/*": [ "src/test-utils/*" ]
    },

    "types": [ "@umbraco-cms/backoffice/extension-types", "vitest/globals" ]
  },
  "include": [ "src" ]
}
